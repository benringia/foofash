{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(node --input-type=module)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(node --test scripts/*.test.mjs)",
      "Bash(shopify version:*)",
      "Bash(shopify theme:*)",
      "Bash(grep -E \"\\\\.\\(js|css\\)$\")",
      "Bash(find shopify/assets -maxdepth 1 \\\\\\( -name \"main-*.js\" -o -name \"main-*.css\" -o -name \"chunk-*.js\" \\\\\\) -delete)",
      "Bash(rm -rf shopify/assets/.vite)",
      "Bash(test -f \"c:\\\\\\\\Users\\\\\\\\Ben\\\\\\\\Documents\\\\\\\\Shopify Projects\\\\\\\\foofash\\\\\\\\shopify\\\\\\\\sections\\\\\\\\service-booking.liquid\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_INPUT_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
