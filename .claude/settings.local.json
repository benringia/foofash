{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(node --input-type=module)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(node -e ':*')",
      "Bash(node --test scripts/*.test.mjs)",
      "Bash(shopify version:*)",
      "Bash(shopify theme:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_INPUT_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}