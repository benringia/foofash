<footer class='bg-primary-dim rounded-t-[5rem] pt-20' role='contentinfo'>
  <div class='mx-auto max-w-7xl px-12 pb-20'>
    <div class='grid grid-cols-1 gap-16 md:grid-cols-2 lg:grid-cols-4'>
      {%- comment -%} Brand column — spans 2 cols on lg {%- endcomment -%}
      <div class='col-span-1 lg:col-span-2'>
        <h2 class='mb-6 flex items-center gap-2 text-4xl font-extrabold text-white'>
          <span class='h-10 w-10 text-secondary' aria-hidden='true'>
            {%- render 'icon', icon: 'paw' -%}
          </span>
          {{ shop.name }}
        </h2>
        {%- if section.settings.tagline != blank -%}
          <p class='mb-10 max-w-sm text-lg leading-relaxed text-white/60'>{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- comment -%} Social icons {%- endcomment -%}
        <div class='flex gap-4'>
          {%- if section.settings.footer_instagram != blank -%}
            <a
              href='{{ section.settings.footer_instagram }}'
              class='flex h-12 w-12 cursor-pointer items-center justify-center rounded-2xl bg-white/5 text-white transition-all hover:bg-secondary'
              aria-label='Instagram'
            >
              <span class='h-5 w-5 block' aria-hidden='true'>{%- render 'icon', icon: 'instagram' -%}</span>
            </a>
          {%- endif -%}
          {%- if section.settings.footer_facebook != blank -%}
            <a
              href='{{ section.settings.footer_facebook }}'
              class='flex h-12 w-12 cursor-pointer items-center justify-center rounded-2xl bg-white/5 text-white transition-all hover:bg-secondary'
              aria-label='Facebook'
            >
              <span class='h-5 w-5 block' aria-hidden='true'>{%- render 'icon', icon: 'facebook' -%}</span>
            </a>
          {%- endif -%}
          {%- if section.settings.footer_twitter != blank -%}
            <a
              href='{{ section.settings.footer_twitter }}'
              class='flex h-12 w-12 cursor-pointer items-center justify-center rounded-2xl bg-white/5 text-white transition-all hover:bg-secondary'
              aria-label='Twitter / X'
            >
              <span class='h-5 w-5 block' aria-hidden='true'>{%- render 'icon', icon: 'twitter' -%}</span>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Nav column 1 {%- endcomment -%}
      {%- assign col1_links = linklists[section.settings.footer_col_1_menu].links -%}
      {%- if col1_links.size > 0 -%}
        <nav aria-label='{{ section.settings.footer_col_1_label | default: 'Navigation' }}'>
          {%- if section.settings.footer_col_1_label != blank -%}
            <p class='mb-8 text-sm font-black uppercase tracking-widest text-secondary'>
              {{ section.settings.footer_col_1_label }}
            </p>
          {%- endif -%}
          <ul class='flex flex-col gap-4' role='list'>
            {%- for link in col1_links -%}
              <li>
                <a href='{{ link.url }}' class='block font-medium text-white/60 transition-colors hover:text-white'>
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      {%- comment -%} Newsletter column {%- endcomment -%}
      <div class='flex flex-col gap-4'>
        {%- if section.settings.newsletter_heading != blank -%}
          <p class='mb-4 text-sm font-black uppercase tracking-widest text-secondary'>
            {{ section.settings.newsletter_heading }}
          </p>
        {%- endif -%}
        <p class='text-sm font-medium text-white/60'>
          {{
            section.settings.newsletter_subtext
            | default: 'Join our pack for monthly pet health tips and exclusive offers.'
          }}
        </p>
        <form
          action='/contact#newsletter'
          method='post'
          data-newsletter-form
          class='flex flex-col gap-3'
        >
          <input type='hidden' name='form_type' value='customer'>
          <input type='hidden' name='utf8' value='✓'>
          <label for='footer-newsletter-email' class='sr-only'>Email address</label>
          <input
            type='email'
            id='footer-newsletter-email'
            name='contact[email]'
            placeholder='{{ section.settings.newsletter_placeholder | default: 'Your email address' }}'
            required
            class='w-full rounded-2xl border border-white/10 bg-white/5 px-6 py-4 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-secondary'
          >
          <button
            type='submit'
            class='w-full rounded-2xl bg-secondary py-4 text-sm font-bold text-white transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-primary-dim'
          >
            Join the Pack
          </button>
        </form>
      </div>
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class='mt-20 flex flex-col items-center justify-between gap-8 border-t border-white/5 pt-10 md:flex-row'>
      <p class='text-sm font-medium text-white/40'>
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name }}
        {%- if section.settings.copyright_text != blank -%}
          &nbsp;&mdash;&nbsp;{{ section.settings.copyright_text }}
        {%- endif -%}
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Redefining pet wellness through joyful care and premium products. Join our community of healthy, happy pets."
    },
    {
      "type": "header",
      "content": "Navigation columns"
    },
    {
      "type": "text",
      "id": "footer_col_1_label",
      "label": "Column 1 label",
      "default": "Navigation"
    },
    {
      "type": "link_list",
      "id": "footer_col_1_menu",
      "label": "Column 1 menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Join our pack for monthly pet health tips and exclusive offers."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "footer_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "footer_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "footer_twitter",
      "label": "Twitter / X URL"
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "placeholder": "All rights reserved."
    }
  ]
}
{% endschema %}
