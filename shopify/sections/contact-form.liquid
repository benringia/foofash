<section class='contact-form {{ section.settings.padding }} border-t border-gray-100'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='mx-auto max-w-xl'>
      <div class='mb-8'>
        <p class='text-sm font-semibold uppercase tracking-widest text-green-600'>Get in Touch</p>
        {%- if section.settings.heading != blank -%}
          <h2 class='mt-1 text-2xl font-bold text-gray-900 sm:text-3xl'>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- form 'contact' -%}
        {%- if form.posted_successfully -%}
          <div class='rounded-lg border border-green-200 bg-green-50 p-4' role='alert'>
            <p class='text-sm font-medium text-green-800'>Thanks for reaching out! We&rsquo;ll be in touch soon.</p>
          </div>

        {%- else -%}
          {%- if form.errors -%}
            <div class='mb-6 rounded-lg border border-red-200 bg-red-50 p-4' role='alert'>
              <p class='mb-2 text-sm font-medium text-red-700'>Please fix the following errors:</p>
              <ul class='list-inside list-disc text-sm text-red-600'>
                {%- for field in form.errors.translated_fields -%}
                  <li>
                    {{ field | capitalize }}
                    {{ form.errors.messages[field] }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class='flex flex-col gap-5'>
            <div class='flex flex-col gap-1'>
              <label for='contact-name' class='text-sm font-medium text-gray-700'>
                Name <span class='text-red-500' aria-hidden='true'>*</span>
              </label>
              <input
                id='contact-name'
                type='text'
                name='contact[name]'
                value='{{ form.name }}'
                required
                autocomplete='name'
                class='rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
              >
            </div>

            <div class='flex flex-col gap-1'>
              <label for='contact-email' class='text-sm font-medium text-gray-700'>
                Email <span class='text-red-500' aria-hidden='true'>*</span>
              </label>
              <input
                id='contact-email'
                type='email'
                name='contact[email]'
                value='{{ form.email }}'
                required
                autocomplete='email'
                class='rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
              >
            </div>

            <div class='flex flex-col gap-1'>
              <label for='contact-subject' class='text-sm font-medium text-gray-700'>Subject</label>
              <input
                id='contact-subject'
                type='text'
                name='contact[subject]'
                value='{{ form.subject }}'
                autocomplete='off'
                class='rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
              >
            </div>

            <div class='flex flex-col gap-1'>
              <label for='contact-message' class='text-sm font-medium text-gray-700'>
                Message <span class='text-red-500' aria-hidden='true'>*</span>
              </label>
              <textarea
                id='contact-message'
                name='contact[body]'
                required
                rows='6'
                class='rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
              >{{ form.body }}</textarea>
            </div>

            <button
              type='submit'
              class='w-full rounded-lg bg-green-600 px-6 py-3 font-semibold text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2'
            >
              Send Message
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Send Us a Message"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-10 lg:py-16", "label": "Medium" },
        { "value": "py-16 lg:py-24", "label": "Large" }
      ],
      "default": "py-10 lg:py-16"
    }
  ]
}
{% endschema %}
