{%- if section.blocks.size > 0 -%}
  <div class='trust-bar bg-surface-low {{ section.settings.padding }}'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <ul
        class='grid grid-cols-2 gap-4 md:grid-cols-4 lg:gap-6'
        role='list'
      >
        {%- for block in section.blocks -%}
          <li
            class='flex flex-col items-center gap-3 rounded-3xl bg-surface-lowest p-6 text-center shadow-ambient'
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.icon != blank -%}
              <span
                class='flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary'
                aria-hidden='true'
              >
                {%- render 'icon', icon: block.settings.icon -%}
              </span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class='text-sm font-semibold text-on-surface'>{{ block.settings.title }}</p>
            {%- endif -%}

            {%- if block.settings.subtitle != blank -%}
              <p class='text-xs text-on-surface/60'>{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 6,
  "settings": [
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-4", "label": "Small" },
        { "value": "py-6", "label": "Medium" },
        { "value": "py-10", "label": "Large" }
      ],
      "default": "py-10"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "Supported: vet-approved, shipping, returns, paw, clock, phone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "info": "Optional supporting text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "vet-approved",
            "title": "Vet Approved",
            "subtitle": "Clinical recommendations only"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "stethoscope",
            "title": "Licensed Vets",
            "subtitle": "50+ on store"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "clock",
            "title": "24/7 Care",
            "subtitle": "Always available"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "paw",
            "title": "Premium Shop",
            "subtitle": "Handpicked products"
          }
        }
      ]
    }
  ]
}
{% endschema %}
