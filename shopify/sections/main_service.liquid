{%- assign has_highlights = false -%}
{%- if section.settings.price != blank
  or section.settings.duration != blank
  or section.settings.benefit_1 != blank
  or section.settings.benefit_2 != blank
  or section.settings.benefit_3 != blank
-%}
  {%- assign has_highlights = true -%}
{%- endif -%}

<section class='main-service {{ section.settings.padding }}'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    {%- comment -%} Hero: two-column layout {%- endcomment -%}
    <div class='grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center'>
      {%- comment -%} Left: badge, title, content, CTA {%- endcomment -%}
      <div class='flex flex-col gap-6'>
        {%- if section.settings.hero_badge != blank -%}
          <div class='inline-flex items-center gap-3 self-start rounded-full border border-primary/5 bg-white px-5 py-2 shadow-bubbly'>
            <span class='h-2 w-2 animate-pulse rounded-full bg-secondary' aria-hidden='true'></span>
            <span class='text-xs font-black uppercase tracking-widest text-primary'>
              {{- section.settings.hero_badge -}}
            </span>
          </div>
        {%- endif -%}

        <h1 class='font-display text-5xl font-extrabold leading-tight text-primary lg:text-6xl'>
          {{ page.title }}
        </h1>

        {%- if page.content != blank -%}
          <div class='prose max-w-lg text-xl font-medium leading-relaxed text-on-surface-variant'>
            {{ page.content }}
          </div>
        {%- endif -%}

        {%- if section.settings.hero_cta_text != blank -%}
          <div>
            <a
              href='#booking'
              class='inline-block rounded-full bg-primary px-10 py-5 text-lg font-bold text-white shadow-bubbly-lg transition-all hover:-translate-y-1 hover:bg-primary-dim focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
            >
              {{ section.settings.hero_cta_text }}
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: hero image with blob background {%- endcomment -%}
      <div class='relative flex items-center justify-center'>
        <div
          class='absolute inset-0 rounded-full bg-medical-green opacity-60 blur-3xl'
          aria-hidden='true'
        ></div>
        {%- if section.settings.hero_image != blank -%}
          <div class='relative w-full overflow-hidden rounded-[3rem] shadow-bubbly-lg'>
            {{
              section.settings.hero_image
              | image_url: width: 1000
              | image_tag: alt: page.title, class: 'h-[400px] w-full object-cover lg:h-[500px]', loading: 'lazy'
            }}
          </div>
        {%- else -%}
          <div
            class='relative flex h-[400px] w-full items-center justify-center rounded-[3rem] bg-primary/10'
            aria-hidden='true'
          >
            <span class='h-24 w-24 text-primary/20'>
              {%- render 'icon', icon: 'paw' -%}
            </span>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Conversion card — only renders when at least one detail is set {%- endcomment -%}
    {%- if has_highlights -%}
      <div class='mx-auto mt-16 max-w-2xl rounded-3xl bg-surface-container p-8 lg:p-10'>
        <div class='mb-6 flex items-center justify-between'>
          <h2 class='text-xl font-bold text-primary'>Service Details</h2>
          <span class='rounded-full bg-medical-green px-4 py-1.5 text-xs font-bold text-primary'>
            Available Today
          </span>
        </div>

        {%- if section.settings.price != blank or section.settings.duration != blank -%}
          <dl class='mb-6 divide-y divide-primary/10'>
            {%- if section.settings.price != blank -%}
              <div class='flex items-center justify-between py-3'>
                <dt class='text-sm font-medium text-on-surface-variant'>Price</dt>
                <dd class='text-sm font-bold text-primary'>{{ section.settings.price | escape }}</dd>
              </div>
            {%- endif -%}
            {%- if section.settings.duration != blank -%}
              <div class='flex items-center justify-between py-3'>
                <dt class='text-sm font-medium text-on-surface-variant'>Duration</dt>
                <dd class='text-sm font-bold text-primary'>{{ section.settings.duration | escape }}</dd>
              </div>
            {%- endif -%}
          </dl>
        {%- endif -%}

        {%- if section.settings.benefit_1 != blank
          or section.settings.benefit_2 != blank
          or section.settings.benefit_3 != blank
        -%}
          <ul class='mb-8 space-y-3'>
            {%- if section.settings.benefit_1 != blank -%}
              <li class='flex items-start gap-3 text-sm text-on-surface-variant'>
                <span class='mt-0.5 flex-none font-bold text-primary' aria-hidden='true'>&check;</span>
                {{ section.settings.benefit_1 | escape }}
              </li>
            {%- endif -%}
            {%- if section.settings.benefit_2 != blank -%}
              <li class='flex items-start gap-3 text-sm text-on-surface-variant'>
                <span class='mt-0.5 flex-none font-bold text-primary' aria-hidden='true'>&check;</span>
                {{ section.settings.benefit_2 | escape }}
              </li>
            {%- endif -%}
            {%- if section.settings.benefit_3 != blank -%}
              <li class='flex items-start gap-3 text-sm text-on-surface-variant'>
                <span class='mt-0.5 flex-none font-bold text-primary' aria-hidden='true'>&check;</span>
                {{ section.settings.benefit_3 | escape }}
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        <a
          href='#booking'
          class='block rounded-full bg-primary px-10 py-5 text-center text-lg font-bold text-white shadow-bubbly-lg transition-all hover:-translate-y-1 hover:bg-primary-dim focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
        >
          {{ section.settings.hero_cta_text | default: 'Book Appointment' }}
        </a>
        <p class='mt-3 text-center text-xs font-medium text-on-surface-variant'>Limited slots available today</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Service",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Hero badge",
      "default": "Veterinary Service"
    },
    {
      "type": "text",
      "id": "hero_cta_text",
      "label": "Primary CTA label",
      "default": "Book Appointment"
    },
    {
      "type": "header",
      "content": "Service details"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "info": "e.g. 'From $45'"
    },
    {
      "type": "text",
      "id": "duration",
      "label": "Duration",
      "info": "e.g. '30–60 mins'"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-10 lg:py-16", "label": "Medium" },
        { "value": "py-16 lg:py-24", "label": "Large" }
      ],
      "default": "py-10 lg:py-16"
    }
  ]
}
{% endschema %}
