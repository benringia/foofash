{%- assign has_highlights = false -%}
{%- if section.settings.price != blank
  or section.settings.duration != blank
  or section.settings.benefit_1 != blank
  or section.settings.benefit_2 != blank
  or section.settings.benefit_3 != blank
-%}
  {%- assign has_highlights = true -%}
{%- endif -%}

<section class='main-service {{ section.settings.padding }} border-b border-gray-100'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    {%- if section.settings.hero_image != blank -%}
      <div class='mb-10 overflow-hidden rounded-2xl'>
        {{-
          section.settings.hero_image
          | image_url: width: 1600
          | image_tag: alt: page.title, class: 'w-full h-[280px] md:h-[380px] object-cover', loading: 'lazy'
        -}}
      </div>
    {%- endif -%}

    {%- if section.settings.eyebrow != blank -%}
      <p class='mb-2 text-sm font-semibold uppercase tracking-widest text-green-600'>
        {{ section.settings.eyebrow | escape }}
      </p>
    {%- endif -%}

    <div class='{% if has_highlights %}grid gap-12 lg:grid-cols-2 lg:items-start{% endif %}'>
      <div>
        <h1 class='text-4xl font-bold leading-tight text-gray-900 sm:text-5xl'>
          {{ page.title | escape }}
        </h1>

        {%- if page.content != blank -%}
          <div class='mt-6 text-lg leading-relaxed text-gray-600'>
            {{ page.content }}
          </div>
        {%- endif -%}
      </div>

      {%- if has_highlights -%}
        <div class='relative rounded-2xl bg-green-50 p-6'>
          <span class='absolute right-4 top-4 rounded-full bg-green-600 px-3 py-1 text-xs font-semibold text-white'>
            Available Today
          </span>

          <h2 class='mb-4 text-lg font-semibold text-gray-900'>Service Details</h2>

          {%- if section.settings.price != blank or section.settings.duration != blank -%}
            <dl class='mb-4 divide-y divide-green-100'>
              {%- if section.settings.price != blank -%}
                <div class='flex items-center justify-between py-3 text-sm'>
                  <dt class='text-gray-500'>Price</dt>
                  <dd class='font-medium text-gray-900'>{{ section.settings.price | escape }}</dd>
                </div>
              {%- endif -%}
              {%- if section.settings.duration != blank -%}
                <div class='flex items-center justify-between py-3 text-sm'>
                  <dt class='text-gray-500'>Duration</dt>
                  <dd class='font-medium text-gray-900'>{{ section.settings.duration | escape }}</dd>
                </div>
              {%- endif -%}
            </dl>
          {%- endif -%}

          {%- if section.settings.benefit_1 != blank
            or section.settings.benefit_2 != blank
            or section.settings.benefit_3 != blank
          -%}
            <ul class='mb-6 space-y-2'>
              {%- if section.settings.benefit_1 != blank -%}
                <li class='flex items-start gap-2 text-sm text-gray-700'>
                  <span class='mt-0.5 flex-none font-semibold text-green-600' aria-hidden='true'>&check;</span>
                  {{ section.settings.benefit_1 | escape }}
                </li>
              {%- endif -%}
              {%- if section.settings.benefit_2 != blank -%}
                <li class='flex items-start gap-2 text-sm text-gray-700'>
                  <span class='mt-0.5 flex-none font-semibold text-green-600' aria-hidden='true'>&check;</span>
                  {{ section.settings.benefit_2 | escape }}
                </li>
              {%- endif -%}
              {%- if section.settings.benefit_3 != blank -%}
                <li class='flex items-start gap-2 text-sm text-gray-700'>
                  <span class='mt-0.5 flex-none font-semibold text-green-600' aria-hidden='true'>&check;</span>
                  {{ section.settings.benefit_3 | escape }}
                </li>
              {%- endif -%}
            </ul>
          {%- endif -%}

          <a
            href='#booking'
            class='block rounded-lg bg-green-600 px-6 py-3 text-center font-semibold text-white transition hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2'
          >
            Book Appointment Now
          </a>

          <p class='mt-3 text-center text-xs text-gray-600'>Limited slots available today</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Service",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small label above the page title, e.g. 'Veterinary Services'"
    },
    {
      "type": "header",
      "content": "Service highlights"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "info": "e.g. 'From £45'"
    },
    {
      "type": "text",
      "id": "duration",
      "label": "Duration",
      "info": "e.g. '30–60 mins'"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-10 lg:py-16", "label": "Medium" },
        { "value": "py-16 lg:py-24", "label": "Large" }
      ],
      "default": "py-10 lg:py-16"
    }
  ]
}
{% endschema %}
