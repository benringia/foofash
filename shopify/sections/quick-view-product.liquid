{%- comment -%}
  Minimal product section rendered inside the quick view modal.
  Fetched via /products/{handle}?view=quick-view
  Intentionally lightweight — full PDP logic lives in main-product.liquid.
{%- endcomment -%}

<div class='grid grid-cols-1 gap-6 sm:grid-cols-2'>
  <div class='aspect-square overflow-hidden rounded-lg bg-gray-100'>
    {%- if product.featured_image != blank -%}
      {{
        product.featured_image
        | image_url: width: 600
        | image_tag:
          loading: 'eager',
          width: 600,
          height: 600,
          class: 'h-full w-full object-cover',
          alt: product.featured_image.alt
        | default: product.title
      }}
    {%- else -%}
      <div class='flex h-full w-full items-center justify-center text-gray-300' aria-hidden='true'>
        {%- render 'icon', icon: 'paw' -%}
      </div>
    {%- endif -%}
  </div>

  <div class='flex flex-col gap-4'>
    <div class='flex flex-col gap-1'>
      <h2 class='text-xl font-bold text-gray-900'>{{ product.title }}</h2>
      <div class='text-lg' data-quick-view-price>
        {%- render 'price', product: product -%}
      </div>
    </div>

    {%- form 'product', product, data-cart-form: '' -%}
      <div class='flex flex-col gap-3'>
        {%- unless product.has_only_default_variant -%}
          <div class='flex flex-col gap-1'>
            <label for='qv-variant-select' class='text-sm font-medium text-gray-700'>
              {{ product.options.first }}
            </label>
            <select
              id='qv-variant-select'
              name='id'
              data-variant-selector
              class='rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
            >
              {%- for variant in product.variants -%}
                <option
                  value='{{ variant.id }}'
                  {%- unless variant.available -%}
                    disabled
                  {%- endunless -%}
                >
                  {{ variant.title }}
                  {%- unless variant.available %} – Sold out{%- endunless -%}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- else -%}
          <input type='hidden' name='id' value='{{ product.selected_or_first_available_variant.id }}'>
        {%- endunless -%}

        <div class='flex items-center gap-2'>
          <label for='qv-quantity' class='text-sm font-medium text-gray-700'>Qty</label>
          <input
            id='qv-quantity'
            type='number'
            name='quantity'
            value='1'
            min='1'
            class='w-16 rounded-lg border border-gray-300 px-2 py-2 text-center text-sm focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
          >
        </div>

        <button
          type='submit'
          data-add-to-cart
          {%- unless product.selected_or_first_available_variant.available -%}
            disabled aria-disabled='true'
          {%- endunless -%}
          class='rounded-lg bg-green-600 px-6 py-3 font-semibold text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50'
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Add to cart
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>

        <a
          href='{{ product.url }}'
          class='text-center text-sm text-green-700 underline hover:text-green-900'
        >
          View full details
        </a>
      </div>
    {%- endform -%}
  </div>
</div>

<script type='application/json' data-product-variants>
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Quick View Product",
  "settings": []
}
{% endschema %}
