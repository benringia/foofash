<header
  class='site-header sticky top-0 z-30 bg-surface/95 backdrop-blur-sm shadow-ambient'
  data-header
>
  <div class='mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6'>
    {%- comment -%} Left: logo + brand name {%- endcomment -%}
    <a
      href='{{ routes.root_url }}'
      class='flex flex-none items-center gap-2 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
      aria-label='{{ shop.name }} – home'
    >
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_tag: width: 140, loading: 'eager', alt: shop.name, class: 'h-8 w-auto' }}
      {%- else -%}
        <span class='h-6 w-6 text-primary' aria-hidden='true'>
          {%- render 'icon', icon: 'paw' -%}
        </span>
        <span class='font-display text-lg font-bold text-on-surface'>{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Desktop nav — rendered by navigation snippet {%- endcomment -%}
    {%- render 'navigation',
      menu: section.settings.menu,
      services_page: section.settings.services_page,
      services_label: section.settings.services_label
    -%}

    {%- comment -%} Center: search {%- endcomment -%}
    <div class='relative flex-1' data-predictive-search>
      <form
        role='search'
        action='{{ routes.search_url }}'
        method='get'
        data-predictive-search-form
        class='flex items-center'
      >
        <input type='hidden' name='type' value='product'>
        <label for='predictive-search-input' class='sr-only'>Search products</label>
        <div class='relative w-full max-w-sm mx-auto'>
          <span
            class='pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-on-surface/40'
            aria-hidden='true'
          >
            {%- render 'icon', icon: 'search' -%}
          </span>
          <input
            id='predictive-search-input'
            type='search'
            name='q'
            autocomplete='off'
            autocorrect='off'
            autocapitalize='off'
            spellcheck='false'
            placeholder='{{ section.settings.search_placeholder | default: 'Search products…' }}'
            role='combobox'
            aria-expanded='false'
            aria-controls='predictive-search-results'
            aria-autocomplete='list'
            aria-haspopup='listbox'
            data-predictive-search-input
            class='w-full rounded-full bg-surface-low py-2 pl-9 pr-4 text-sm text-on-surface placeholder-on-surface/40 focus:outline-none focus:ring-2 focus:ring-primary/40 transition-shadow'
          >
        </div>
      </form>
      {%- render 'predictive-search' -%}
    </div>

    {%- comment -%} Right: cart button {%- endcomment -%}
    <button
      type='button'
      data-cart-toggle
      aria-label='Open cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}'
      class='relative flex-none rounded-full p-2 text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
    >
      <span class='h-6 w-6 block' aria-hidden='true'>
        {%- render 'icon', icon: 'bag' -%}
      </span>
      {%- if cart.item_count > 0 -%}
        <span
          class='absolute -right-0.5 -top-0.5 flex h-4 w-4 items-center justify-center rounded-full bg-secondary text-[10px] font-bold text-white'
          aria-hidden='true'
          data-cart-count
        >
          {{- cart.item_count -}}
        </span>
      {%- else -%}
        <span class='sr-only' data-cart-count>{{ cart.item_count }}</span>
      {%- endif -%}
    </button>

    {%- comment -%} Mobile: hamburger toggle {%- endcomment -%}
    <button
      type='button'
      aria-expanded='false'
      aria-controls='mobile-nav-drawer'
      aria-label='Open menu'
      class='flex-none rounded-full p-2 text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 md:hidden'
      data-mobile-toggle
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='22'
        height='22'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        aria-hidden='true'
      >
        <line x1='3' y1='6' x2='21' y2='6'></line>
        <line x1='3' y1='12' x2='21' y2='12'></line>
        <line x1='3' y1='18' x2='21' y2='18'></line>
      </svg>
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products…"
    },
    {
      "type": "text",
      "id": "services_label",
      "label": "Services link label",
      "default": "Services"
    },
    {
      "type": "url",
      "id": "services_page",
      "label": "Services link URL",
      "info": "Link to your main service page. Leave blank to hide."
    }
  ]
}
{% endschema %}
