<header
  class='site-header fixed inset-x-0 top-4 z-50 px-4 sm:px-6'
  data-header
>
  <div class='mx-auto max-w-7xl'>
    <div class='flex items-center justify-between rounded-full bg-white/80 px-8 py-4 shadow-bubbly backdrop-blur-xl border border-white/50'>
      {%- comment -%} LEFT: logo + nav {%- endcomment -%}
      <div class='flex min-w-0 shrink items-center gap-8'>
        <a
          href='{{ routes.root_url }}'
          class='flex shrink-0 items-center gap-2 rounded focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
          aria-label='{{ shop.name }} – home'
        >
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: 240
              | image_tag: width: 120, height: 28, loading: 'eager', alt: shop.name, class: 'h-7 w-auto'
            }}
          {%- else -%}
            <span class='h-6 w-6 shrink-0 text-primary' aria-hidden='true'>
              {%- render 'icon', icon: 'paw' -%}
            </span>
            <span class='font-display text-base font-bold tracking-wide text-on-surface'>
              {{- shop.name | upcase -}}
            </span>
          {%- endif -%}
        </a>

        {%- render 'navigation',
          menu: section.settings.menu,
          services_page: section.settings.services_page,
          services_label: section.settings.services_label
        -%}
      </div>

      {%- comment -%} RIGHT: search + cart {%- endcomment -%}
      <div class='flex shrink-0 items-center gap-3'>
        {%- comment -%} Search pill — hidden on mobile {%- endcomment -%}
        <div class='relative hidden shrink-0 lg:block' data-predictive-search>
          <form
            role='search'
            action='{{ routes.search_url }}'
            method='get'
            data-predictive-search-form
          >
            <input type='hidden' name='type' value='product'>
            <label for='predictive-search-input' class='sr-only'>Search products</label>
            <span
              class='pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-on-surface/40'
              aria-hidden='true'
            >
              {%- render 'icon', icon: 'search' -%}
            </span>
            <input
              id='predictive-search-input'
              type='search'
              name='q'
              autocomplete='off'
              autocorrect='off'
              autocapitalize='off'
              spellcheck='false'
              placeholder='{{ section.settings.search_placeholder | default: 'Search products…' }}'
              role='combobox'
              aria-expanded='false'
              aria-controls='predictive-search-results'
              aria-autocomplete='list'
              aria-haspopup='listbox'
              data-predictive-search-input
              class='h-9 w-[220px] rounded-full bg-surface-container pl-9 pr-4 text-sm text-on-surface placeholder-on-surface/40 transition-[width] duration-200 focus:w-[280px] focus:outline-none focus:ring-2 focus:ring-primary/40 lg:w-[260px] lg:focus:w-[320px]'
            >
          </form>
          {%- render 'predictive-search' -%}
        </div>

        {%- comment -%} Cart button {%- endcomment -%}
        <button
          type='button'
          data-cart-toggle
          aria-label='Open cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}'
          class='relative flex h-12 w-12 shrink-0 cursor-pointer items-center justify-center rounded-full bg-white shadow-bubbly border border-surface-container text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
        >
          <span class='block h-6 w-6' aria-hidden='true'>
            {%- render 'icon', icon: 'bag' -%}
          </span>
          <span
            class='{% unless cart.item_count > 0 %}hidden {% endunless %}absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-secondary text-[10px] font-bold leading-none text-white'
            aria-hidden='true'
            data-cart-count
            data-cart-count-badge
          >
            {{- cart.item_count -}}
          </span>
        </button>

        {%- comment -%} Mobile hamburger {%- endcomment -%}
        <button
          type='button'
          aria-expanded='false'
          aria-controls='mobile-nav-drawer'
          aria-label='Open menu'
          class='flex h-9 w-9 cursor-pointer items-center justify-center rounded-full text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 md:hidden'
          data-mobile-toggle
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='20'
            height='20'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <line x1='3' y1='6' x2='21' y2='6'></line>
            <line x1='3' y1='12' x2='21' y2='12'></line>
            <line x1='3' y1='18' x2='21' y2='18'></line>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

{%- render 'mobile-nav-drawer',
  menu: section.settings.menu,
  services_page: section.settings.services_page,
  services_label: section.settings.services_label
-%}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products…"
    },
    {
      "type": "text",
      "id": "services_label",
      "label": "Services link label",
      "default": "Services"
    },
    {
      "type": "url",
      "id": "services_page",
      "label": "Services link URL",
      "info": "Link to your main service page. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Clinic Navigation"
    },
    {
      "type": "text",
      "id": "clinic_nav_label",
      "label": "Clinic dropdown label",
      "default": "Clinic",
      "info": "The label shown in the nav bar for the Clinic dropdown."
    },
    {
      "type": "text",
      "id": "clinic_cta_label",
      "label": "Clinic CTA label",
      "default": "View all clinic services",
      "info": "Text for the footer link in the Clinic dropdown."
    },
    {
      "type": "url",
      "id": "clinic_cta_url",
      "label": "Clinic CTA URL",
      "info": "Where the footer 'View all' link points. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Shop Navigation"
    },
    {
      "type": "text",
      "id": "shop_nav_label",
      "label": "Shop dropdown label",
      "default": "Shop",
      "info": "The label shown in the nav bar for the Shop dropdown."
    },
    {
      "type": "link_list",
      "id": "shop_featured_menu",
      "label": "Featured links menu",
      "info": "First item is highlighted. Recommended: Shop All, Best Sellers, New Arrivals, Vet Approved."
    },
    {
      "type": "text",
      "id": "shop_featured_label",
      "label": "Featured section heading",
      "default": "Featured"
    },
    {
      "type": "link_list",
      "id": "shop_categories_menu",
      "label": "Categories menu",
      "info": "Pet/product category links. Recommended: Dogs, Cats, Small Animals, Fish."
    },
    {
      "type": "text",
      "id": "shop_categories_label",
      "label": "Categories section heading",
      "default": "Shop by pet"
    },
    {
      "type": "text",
      "id": "shop_cta_label",
      "label": "Shop footer CTA label",
      "default": "Browse all products"
    },
    {
      "type": "url",
      "id": "shop_cta_url",
      "label": "Shop footer CTA URL",
      "info": "Optional footer link in the Shop dropdown. Leave blank to hide."
    }
  ],
  "blocks": [
    {
      "type": "clinic_service",
      "name": "Clinic Service",
      "settings": [
        {
          "type": "product",
          "id": "service_product",
          "label": "Service product",
          "info": "Must be assigned to the 'product.service' template."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Override label",
          "info": "Leave blank to use the product title."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Short description",
          "placeholder": "e.g. Annual health screening"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon key",
          "default": "stethoscope",
          "info": "One of: stethoscope, scissors, syringe, tooth, paw, calendar, clock, vet-approved"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
