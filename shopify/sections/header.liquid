<header class='site-header'>
  <div class='site-header__inner'>
    <a href='{{ routes.root_url }}' class='site-header__logo' aria-label='{{ shop.name }} – home'>
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_tag: width: 160, alt: shop.name }}
      {%- else -%}
        <span>{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav aria-label='Main navigation'>
      {%- for link in linklists[section.settings.menu].links -%}
        <a href='{{ link.url }}'>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <button
      type='button'
      data-cart-toggle
      aria-label='Open cart, {{ cart.item_count }} items'
      class='flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 rounded'
    >
      Cart (<span data-cart-count>{{ cart.item_count }}</span>)
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
