<header class='site-header sticky top-0 z-30 bg-white shadow-sm'>
  <div class='site-header__inner mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6'>
    <a href='{{ routes.root_url }}' class='flex-none' aria-label='{{ shop.name }} – home'>
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_tag: width: 160, alt: shop.name }}
      {%- else -%}
        <span class='text-lg font-bold text-gray-900'>{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- render 'navigation',
      menu: section.settings.menu,
      services_page: section.settings.services_page,
      services_label: section.settings.services_label
    -%}

    <div class='relative flex-1 max-w-xs' data-predictive-search>
      <form role='search' action='{{ routes.search_url }}' method='get' data-predictive-search-form>
        <input type='hidden' name='type' value='product'>
        <label for='predictive-search-input' class='sr-only'>Search products</label>
        <input
          id='predictive-search-input'
          type='search'
          name='q'
          autocomplete='off'
          autocorrect='off'
          autocapitalize='off'
          spellcheck='false'
          placeholder='Search products…'
          role='combobox'
          aria-expanded='false'
          aria-controls='predictive-search-results'
          aria-autocomplete='list'
          aria-haspopup='listbox'
          data-predictive-search-input
          class='w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm placeholder-gray-400 focus:border-green-500 focus:outline-none focus:ring-1 focus:ring-green-500'
        >
      </form>
      {%- render 'predictive-search' -%}
    </div>

    <button
      type='button'
      data-cart-toggle
      aria-label='Open cart, {{ cart.item_count }} items'
      class='flex-none flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 rounded'
    >
      Cart (<span data-cart-count>{{ cart.item_count }}</span>)
    </button>

    <button
      type='button'
      aria-expanded='false'
      aria-controls='mobile-nav-drawer'
      aria-label='Open menu'
      class='flex-none rounded p-1 text-gray-700 hover:text-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 md:hidden'
      data-mobile-toggle
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='24'
        height='24'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        aria-hidden='true'
      >
        <line x1='3' y1='6' x2='21' y2='6'></line>
        <line x1='3' y1='12' x2='21' y2='12'></line>
        <line x1='3' y1='18' x2='21' y2='18'></line>
      </svg>
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "services_label",
      "label": "Services link label",
      "default": "Services"
    },
    {
      "type": "url",
      "id": "services_page",
      "label": "Services link URL",
      "info": "Link to your main service page, e.g. /pages/vet-consultation. Leave blank to hide the link."
    }
  ]
}
{% endschema %}
