{%- liquid
  assign collection = section.settings.collection
  if collection == blank
    assign collection = collections.all
  endif
  assign limit = section.settings.products_to_show
-%}

<section class='featured-collection bg-white py-32 rounded-t-[4rem] rounded-b-[4rem] shadow-bubbly-lg'>
  <div class='mx-auto max-w-7xl px-6'>
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class='mb-12 flex flex-col md:flex-row justify-between items-end gap-6'>
        <div>
          <p class='mb-2 text-xs font-semibold uppercase tracking-widest text-primary/70'>
            {{ section.settings.eyebrow }}
          </p>
          {%- if section.settings.heading != blank -%}
            <h2 class='font-display text-4xl font-extrabold text-primary'>{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class='mt-1 text-on-surface-variant font-medium'>{{ section.settings.subheading }}</p>
          {%- endif -%}
          <div class='mt-4 flex flex-wrap gap-2'>
            <span class='flex items-center gap-1.5 rounded-full bg-surface-container px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'vet-approved' -%}
              </span>
              {{ section.settings.trust_chip_1 }}
            </span>
            <span class='flex items-center gap-1.5 rounded-full bg-surface-container px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'shipping' -%}
              </span>
              {{ section.settings.trust_chip_2 }}
            </span>
            <span class='flex items-center gap-1.5 rounded-full bg-surface-container px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'returns' -%}
              </span>
              {{ section.settings.trust_chip_3 }}
            </span>
          </div>
        </div>
        {%- if section.settings.view_all_label != blank -%}
          <a
            href='{{ section.settings.view_all_link | default: routes.collections_url }}'
            class='flex-shrink-0 rounded-full bg-surface-container text-primary font-bold px-8 py-3 hover:bg-primary hover:text-white transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
          >
            {{ section.settings.view_all_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <ul class='grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4' role='list'>
        {%- for product in collection.products limit: limit -%}
          <li>
            {%- render 'product-card',
              product: product,
              homepage: true,
              badge_vet_label: settings.badge_vet_label,
              badge_sale_label: settings.badge_sale_label
            -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <ul class='grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4' role='list'>
        {%- for i in (1..4) -%}
          <li>
            <article class='bg-background rounded-3xl p-6'>
              <div class='aspect-square animate-pulse rounded-2xl bg-surface-container mb-6'></div>
              <div class='space-y-2'>
                <p class='h-4 w-3/4 animate-pulse rounded-full bg-surface-container'></p>
                <p class='h-4 w-1/3 animate-pulse rounded-full bg-surface-container'></p>
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
      <p class='mt-4 text-center text-sm text-on-surface-variant/50'>
        No products found — assign a collection in the theme editor.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Customer Favorites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Boutique Favorites"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated essentials for a healthy life"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Shop All Best Sellers"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Trust chips"
    },
    {
      "type": "text",
      "id": "trust_chip_1",
      "label": "Trust chip 1",
      "default": "Vet-approved essentials"
    },
    {
      "type": "text",
      "id": "trust_chip_2",
      "label": "Trust chip 2",
      "default": "Free shipping over $50"
    },
    {
      "type": "text",
      "id": "trust_chip_3",
      "label": "Trust chip 3",
      "default": "Easy returns"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
