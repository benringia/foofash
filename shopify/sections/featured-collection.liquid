{%- liquid
  assign collection = section.settings.collection
  if collection == blank
    assign collection = collections.all
  endif
  assign limit = section.settings.products_to_show
-%}

<section class='featured-collection {{ section.settings.padding }}'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    {%- if section.settings.heading != blank -%}
      <h2 class='mb-6 text-2xl font-bold text-gray-900 sm:text-3xl'>
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <ul class='grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4' role='list'>
        {%- for product in collection.products limit: limit -%}
          <li>
            {%- render 'product-card', product: product -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <ul class='grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4' role='list'>
        {%- for i in (1..4) -%}
          <li>
            <article class='flex flex-col gap-3'>
              <div class='aspect-square animate-pulse rounded-lg bg-gray-200'></div>
              <div class='flex flex-col gap-1 px-1'>
                <p class='h-4 w-3/4 animate-pulse rounded bg-gray-200'></p>
                <p class='h-4 w-1/3 animate-pulse rounded bg-gray-200'></p>
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
      <p class='mt-4 text-center text-sm text-gray-400'>No products found — assign a collection in the theme editor.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-16"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
