{%- liquid
  assign collection = section.settings.collection
  if collection == blank
    assign collection = collections.all
  endif
  assign limit = section.settings.products_to_show
-%}

<section class='featured-collection bg-surface {{ section.settings.padding }}'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class='mb-8 flex items-baseline justify-between gap-4'>
        <div>
          {%- if section.settings.heading != blank -%}
            <h2 class='font-display text-3xl font-bold text-on-surface'>{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class='mt-1 text-sm text-on-surface/60'>{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
        {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
          <a
            href='{{ section.settings.view_all_link }}'
            class='flex-shrink-0 rounded-full border border-primary/30 px-5 py-2 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
          >
            {{ section.settings.view_all_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <ul class='grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4' role='list'>
        {%- for product in collection.products limit: limit -%}
          <li>
            {%- render 'product-card', product: product -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <ul class='grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4' role='list'>
        {%- for i in (1..4) -%}
          <li>
            <article class='flex flex-col gap-3'>
              <div class='aspect-square animate-pulse rounded-3xl bg-surface-high'></div>
              <div class='flex flex-col gap-1 px-1'>
                <p class='h-4 w-3/4 animate-pulse rounded-full bg-surface-high'></p>
                <p class='h-4 w-1/3 animate-pulse rounded-full bg-surface-high'></p>
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
      <p class='mt-4 text-center text-sm text-on-surface/40'>
        No products found — assign a collection in the theme editor.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Boutique Favorites"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated essentials for a healthy life"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-16"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
