{%- if section.blocks.size > 0 -%}
  <section class='services-grid bg-surface-container-low {{ section.settings.padding }}'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class='mb-14 text-center'>
          {%- if section.settings.heading != blank -%}
            <h2 class='font-display text-4xl font-extrabold text-primary'>{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class='mt-3 text-lg font-medium text-on-surface-variant'>{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <ul class='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4' role='list'>
        {%- for block in section.blocks -%}
          <li
            class='group relative flex flex-col overflow-hidden rounded-3xl border border-white/60 bg-white/80 p-6 shadow-bubbly backdrop-blur-md transition-all duration-300 hover:-translate-y-2 hover:shadow-bubbly-lg md:p-8'
            {{ block.shopify_attributes }}
          >
            {%- comment -%} Gradient glow — fades in on hover behind all content {%- endcomment -%}
            <div
              class='pointer-events-none absolute inset-0 bg-gradient-to-br from-medical-green/10 to-secondary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100'
              aria-hidden='true'
            ></div>

            {%- comment -%} Optional badge tag {%- endcomment -%}
            {%- if block.settings.badge != blank -%}
              <span class='relative mb-4 inline-block self-start rounded-full bg-secondary/10 px-3 py-1 text-xs font-semibold text-secondary'>
                {{- block.settings.badge -}}
              </span>
            {%- endif -%}

            {%- comment -%} Icon {%- endcomment -%}
            {%- if block.settings.icon != blank -%}
              <span
                class='relative mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-medical-green/10 text-primary transition-all duration-300 group-hover:scale-110 group-hover:bg-medical-green/20'
                aria-hidden='true'
              >
                <span class='h-6 w-6'>{%- render 'icon', icon: block.settings.icon -%}</span>
              </span>
            {%- endif -%}

            {%- comment -%} Title {%- endcomment -%}
            {%- if block.settings.title != blank -%}
              <h3 class='relative text-lg font-semibold text-primary'>{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- comment -%} Description {%- endcomment -%}
            {%- if block.settings.description != blank -%}
              <p class='relative mt-2 flex-1 text-sm leading-relaxed text-on-surface-variant'>
                {{ block.settings.description }}
              </p>
            {%- endif -%}

            {%- comment -%} CTA pill button with arrow {%- endcomment -%}
            {%- if block.settings.cta_url != blank -%}
              <a
                href='{{ block.settings.cta_url }}'
                class='relative mt-6 inline-flex items-center gap-2 self-start rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-white shadow-bubbly transition-all duration-200 hover:bg-primary-dim hover:shadow-bubbly-lg focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
              >
                {{- block.settings.cta_label | default: 'Book Now' -}}
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='14'
                  height='14'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                  class='transition-transform duration-200 group-hover:translate-x-1'
                >
                  <line x1='5' y1='12' x2='19' y2='12'></line>
                  <polyline points='12 5 19 12 12 19'></polyline>
                </svg>
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- else -%}
  <section class='services-grid bg-surface-container-low {{ section.settings.padding }}'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
      <p class='text-center text-sm text-on-surface/40'>Add service cards using the theme editor.</p>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Services Grid",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-10 lg:py-16", "label": "Medium" },
        { "value": "py-16 lg:py-24", "label": "Large" }
      ],
      "default": "py-10 lg:py-16"
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service card",
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label",
          "info": "Optional tag shown above the icon, e.g. 'Most Popular'"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "Supported: stethoscope, scissors, syringe, tooth, paw, clock, phone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Book Now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services Grid",
      "blocks": [
        {
          "type": "service_card",
          "settings": {
            "icon": "stethoscope",
            "title": "Vet Consultation",
            "description": "Professional health checks and diagnostics for your pet.",
            "cta_label": "Book Now",
            "cta_url": "/pages/vet-consultation"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "badge": "Most Popular",
            "icon": "scissors",
            "title": "Grooming",
            "description": "Full grooming services including wash, cut, and nail trim.",
            "cta_label": "Book Now",
            "cta_url": "/pages/grooming"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "icon": "syringe",
            "title": "Vaccination",
            "description": "Keep your pet protected with up-to-date vaccinations.",
            "cta_label": "Book Now",
            "cta_url": "/pages/vaccination"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "icon": "tooth",
            "title": "Dental Care",
            "description": "Professional dental cleaning and oral health checks.",
            "cta_label": "Book Now",
            "cta_url": "/pages/dental-care"
          }
        }
      ]
    }
  ]
}
{% endschema %}
