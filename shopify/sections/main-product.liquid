{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign inventory_qty = 0 -%}
{%- if variant.inventory_management == 'shopify' -%}
  {%- assign inventory_qty = variant.inventory_quantity -%}
{%- endif -%}

<section
  class='main-product bg-surface-container-low'
  style='padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;'
>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    {%- comment -%} ── Main two-column grid: 60 / 40 ── {%- endcomment -%}
    <div class='grid grid-cols-1 gap-8 lg:grid-cols-[3fr_2fr] lg:items-start lg:gap-16'>
      {%- comment -%}
        ══════════════════════════════════
          LEFT — product media
        ══════════════════════════════════
      {%- endcomment -%}
      <div class='product-media relative'>
        {%- comment -%} Ambient blob behind the image {%- endcomment -%}
        <div
          class='pointer-events-none absolute -inset-8 rounded-full bg-primary/5 blur-3xl'
          aria-hidden='true'
        ></div>

        {%- comment -%} Main image — floating card {%- endcomment -%}
        <div class='group relative overflow-hidden rounded-[3rem] bg-surface shadow-bubbly-lg'>
          {%- if product.featured_image != blank -%}
            {%- assign main_img_alt = product.featured_image.alt | default: product.title -%}
            {{
              product.featured_image
              | image_url: width: 900
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                width: 900,
                height: 900,
                class: 'h-full w-full object-cover transition-transform duration-700 group-hover:scale-105',
                alt: main_img_alt,
                data-main-image: ''
            }}
          {%- else -%}
            <div
              class='flex aspect-square w-full items-center justify-center text-primary/20'
              aria-hidden='true'
              data-main-image
            >
              <span class='block h-32 w-32'>
                {%- render 'icon', icon: 'paw' -%}
              </span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Thumbnail strip — only shown when product has multiple images {%- endcomment -%}
        {%- if product.images.size > 1 -%}
          <div
            class='mt-4 flex gap-3 overflow-x-auto pb-2'
            role='list'
            aria-label='Product images'
          >
            {%- for image in product.images -%}
              <button
                type='button'
                role='listitem'
                data-thumbnail
                data-image-url='{{ image | image_url: width: 900 }}'
                class='h-20 w-20 shrink-0 cursor-pointer overflow-hidden rounded-2xl transition-all duration-200 hover:ring-2 hover:ring-primary/50 focus:outline-none focus:ring-2 focus:ring-primary {% if forloop.first %}ring-2 ring-primary{% else %}ring-2 ring-transparent{% endif %}'
                aria-label='View image {{ forloop.index }} of {{ product.images.size }}'
                {% if forloop.first %}
                  aria-pressed='true'
                {% else %}
                  aria-pressed='false'
                {% endif %}
              >
                {{
                  image
                  | image_url: width: 160
                  | image_tag: loading: 'lazy', width: 80, height: 80, class: 'h-full w-full object-cover'
                }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}
        ══════════════════════════════════
          RIGHT — product info
        ══════════════════════════════════
      {%- endcomment -%}
      <div class='product-info flex flex-col'>
        {%- comment -%} ── CLUSTER 1: Eyebrow + Title + Rating ── {%- endcomment -%}
        <div class='flex flex-col gap-2'>
          {%- if product.type != blank -%}
            <p class='text-xs font-semibold uppercase tracking-widest text-on-surface-variant'>
              {{ product.type }}
            </p>
          {%- endif -%}
          <h1 class='text-3xl font-extrabold leading-[1.15] text-on-surface lg:text-4xl xl:text-[2.75rem]'>
            {{ product.title }}
          </h1>
          {%- render 'rating-stars', product: product -%}
        </div>

        {%- comment -%} ── CLUSTER 2: Price + savings ── {%- endcomment -%}
        <div class='mt-5 flex flex-wrap items-baseline gap-3' data-pdp-price>
          <div class='text-3xl font-black leading-none'>
            {%- render 'price', product: product -%}
          </div>
          {%- if variant.compare_at_price > variant.price -%}
            {%- assign savings = variant.compare_at_price | minus: variant.price -%}
            <span class='rounded-full bg-secondary/15 px-3 py-1 text-sm font-bold text-secondary'>
              Save {{ savings | money }}
            </span>
          {%- endif -%}
        </div>

        {%- comment -%} ── CLUSTER 3: Trust + urgency badges ── {%- endcomment -%}
        {%- assign show_badges = false -%}
        {%- if product.metafields.pet.vet_approved.value == true
          or inventory_qty <= 5
          and inventory_qty > 0
          or section.settings.show_urgency
        -%}
          {%- assign show_badges = true -%}
        {%- endif -%}
        {%- if show_badges -%}
          <div class='mt-3 flex flex-wrap gap-2'>
            {%- if product.metafields.pet.vet_approved.value == true -%}
              <span class='flex items-center gap-1.5 rounded-full bg-medical-green px-3 py-1.5 text-xs font-semibold text-primary'>
                <span class='block h-3.5 w-3.5 shrink-0' aria-hidden='true'>
                  {%- render 'icon', icon: 'vet-approved' -%}
                </span>
                Vet Approved
              </span>
            {%- endif -%}
            {%- if inventory_qty <= 5 and inventory_qty > 0 -%}
              <span class='flex items-center gap-1.5 rounded-full bg-secondary/15 px-3 py-1.5 text-xs font-semibold text-secondary'>
                Only {{ inventory_qty }} left in stock
              </span>
            {%- endif -%}
            {%- if section.settings.show_urgency -%}
              <span class='flex items-center gap-1.5 rounded-full bg-medical-blue px-3 py-1.5 text-xs font-semibold text-tertiary'>
                <span class='block h-3.5 w-3.5 shrink-0' aria-hidden='true'>
                  {%- render 'icon', icon: 'clock' -%}
                </span>
                Order before 3PM for same-day dispatch
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} ── CLUSTER 4: Benefit strip (schema-controlled quick-sell points) ── {%- endcomment -%}
        {%- assign has_benefits = false -%}
        {%- if section.settings.benefit_1 != blank
          or section.settings.benefit_2 != blank
          or section.settings.benefit_3 != blank
        -%}
          {%- assign has_benefits = true -%}
        {%- endif -%}
        {%- if has_benefits -%}
          <ul class='mt-4 flex flex-col gap-2' aria-label='Product benefits'>
            {%- if section.settings.benefit_1 != blank -%}
              <li class='flex items-start gap-2 text-sm text-on-surface-variant'>
                <svg
                  class='mt-0.5 h-4 w-4 shrink-0 text-primary'
                  viewBox='0 0 16 16'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M3 8l3.5 3.5L13 4.5'/>
                </svg>
                {{ section.settings.benefit_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.benefit_2 != blank -%}
              <li class='flex items-start gap-2 text-sm text-on-surface-variant'>
                <svg
                  class='mt-0.5 h-4 w-4 shrink-0 text-primary'
                  viewBox='0 0 16 16'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M3 8l3.5 3.5L13 4.5'/>
                </svg>
                {{ section.settings.benefit_2 }}
              </li>
            {%- endif -%}
            {%- if section.settings.benefit_3 != blank -%}
              <li class='flex items-start gap-2 text-sm text-on-surface-variant'>
                <svg
                  class='mt-0.5 h-4 w-4 shrink-0 text-primary'
                  viewBox='0 0 16 16'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M3 8l3.5 3.5L13 4.5'/>
                </svg>
                {{ section.settings.benefit_3 }}
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- comment -%} ── CLUSTER 5: Product form ── {%- endcomment -%}
        {%- form 'product', product, data-cart-form: '' -%}
          <div class='mt-6 flex flex-col gap-4'>
            {%- comment -%} Variant selector — pill UI backed by hidden select {%- endcomment -%}
            {%- unless product.has_only_default_variant -%}
              <div class='flex flex-col gap-2.5'>
                <p class='text-sm font-semibold text-on-surface-variant'>
                  {{ product.options.first }}:
                  <span class='font-semibold text-on-surface' data-selected-variant-label>
                    {{- variant.title -}}
                  </span>
                </p>

                {%- comment -%} Hidden select preserves all existing JS contracts {%- endcomment -%}
                <select
                  name='id'
                  data-variant-selector
                  class='sr-only'
                  aria-label='{{ product.options.first }}'
                >
                  {%- for v in product.variants -%}
                    <option
                      value='{{ v.id }}'
                      {%- unless v.available -%}
                        disabled
                      {%- endunless -%}
                    >
                      {{ v.title }}
                    </option>
                  {%- endfor -%}
                </select>

                {%- comment -%} Visual pill buttons synced to the hidden select by product.js {%- endcomment -%}
                <div
                  class='flex flex-wrap gap-2'
                  role='group'
                  aria-label='{{ product.options.first }}'
                >
                  {%- for v in product.variants -%}
                    <button
                      type='button'
                      data-variant-pill
                      data-variant-id='{{ v.id }}'
                      data-available='{{ v.available }}'
                      aria-pressed='{% if forloop.first %}true{% else %}false{% endif %}'
                      class='rounded-2xl px-5 py-2.5 text-sm font-semibold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 {% if forloop.first %}bg-primary text-on-primary shadow-bubbly{% else %}bg-surface text-on-surface shadow-ambient hover:bg-primary/10{% endif %} {% unless v.available %}cursor-not-allowed opacity-40{% endunless %}'
                    >
                      {{ v.title }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              <input
                type='hidden'
                name='id'
                value='{{ variant.id }}'
              >
            {%- endunless -%}

            {%- comment -%} Quantity stepper + ATC {%- endcomment -%}
            <div class='flex items-stretch gap-3'>
              {%- comment -%} Stepper {%- endcomment -%}
              <div
                class='flex items-center overflow-hidden rounded-2xl bg-surface shadow-ambient'
                aria-label='Quantity'
              >
                <button
                  type='button'
                  data-qty-decrease
                  aria-label='Decrease quantity'
                  class='flex h-full w-12 cursor-pointer items-center justify-center text-xl text-on-surface transition-colors hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary'
                >
                  <span aria-hidden='true'>&#8722;</span>
                </button>
                <input
                  id='quantity'
                  type='number'
                  name='quantity'
                  value='1'
                  min='1'
                  aria-label='Quantity'
                  class='w-12 bg-transparent text-center text-sm font-semibold text-on-surface focus:outline-none'
                >
                <button
                  type='button'
                  data-qty-increase
                  aria-label='Increase quantity'
                  class='flex h-full w-12 cursor-pointer items-center justify-center text-xl text-on-surface transition-colors hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary'
                >
                  <span aria-hidden='true'>&#43;</span>
                </button>
              </div>

              {%- comment -%} Add to cart — also the sticky-atc.js observer target {%- endcomment -%}
              <button
                type='submit'
                data-add-to-cart
                data-main-atc
                {%- unless variant.available -%}
                  disabled
                  aria-disabled='true'
                {%- endunless -%}
                class='flex-1 rounded-2xl bg-primary-gradient py-5 text-base font-bold text-on-primary transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:scale-100 disabled:cursor-not-allowed disabled:opacity-50'
              >
                {%- if variant.available -%}
                  Add to Cart
                {%- else -%}
                  Sold Out
                {%- endif -%}
              </button>
            </div>

            {%- comment -%} Microcopy under CTA — 3 reassurance items {%- endcomment -%}
            <div class='flex flex-wrap gap-x-5 gap-y-2 text-xs text-on-surface-variant'>
              <span class='flex items-center gap-1.5'>
                <span class='block h-3.5 w-3.5 shrink-0' aria-hidden='true'>
                  {%- render 'icon', icon: 'shipping' -%}
                </span>
                Free shipping over $50
              </span>
              <span class='flex items-center gap-1.5'>
                <span class='block h-3.5 w-3.5 shrink-0' aria-hidden='true'>
                  {%- render 'icon', icon: 'returns' -%}
                </span>
                Easy 30-day returns
              </span>
              {%- if section.settings.show_urgency -%}
                <span class='flex items-center gap-1.5'>
                  <span class='block h-3.5 w-3.5 shrink-0' aria-hidden='true'>
                    {%- render 'icon', icon: 'clock' -%}
                  </span>
                  Same-day dispatch before 3PM
                </span>
              {%- endif -%}
            </div>
          </div>
        {%- endform -%}

        {%- comment -%} ── CLUSTER 6: Accordion tabs ── {%- endcomment -%}
        <div class='mt-6 flex flex-col divide-y divide-on-surface/8'>
          {%- comment -%} Description {%- endcomment -%}
          {%- if product.description != blank -%}
            <div data-accordion>
              <button
                type='button'
                data-accordion-trigger
                aria-expanded='true'
                class='flex w-full items-center justify-between py-4 text-left text-sm font-semibold text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary'
              >
                <span class='flex items-center gap-2'>
                  <svg
                    class='h-4 w-4 shrink-0 text-on-surface-variant'
                    viewBox='0 0 16 16'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <rect x='2' y='2' width='12' height='12' rx='2'/><path d='M5 5h6M5 8h6M5 11h4'/>
                  </svg>
                  Description
                </span>
                <span
                  class='block h-5 w-5 shrink-0 text-on-surface-variant transition-transform duration-200 [[aria-expanded=true]_&]:rotate-180'
                  aria-hidden='true'
                >
                  <svg
                    viewBox='0 0 20 20'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.75'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  >
                    <path d='M5 7.5l5 5 5-5'/>
                  </svg>
                </span>
              </button>
              <div
                data-accordion-panel
                class='prose prose-sm max-w-none pb-5 text-on-surface-variant'
              >
                {{ product.description }}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Ingredients (metafield) {%- endcomment -%}
          {%- if product.metafields.pet.ingredients != blank -%}
            <div data-accordion>
              <button
                type='button'
                data-accordion-trigger
                aria-expanded='false'
                class='flex w-full items-center justify-between py-4 text-left text-sm font-semibold text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary'
              >
                <span class='flex items-center gap-2'>
                  <svg
                    class='h-4 w-4 shrink-0 text-on-surface-variant'
                    viewBox='0 0 16 16'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    aria-hidden='true'
                  >
                    <path d='M8 2c0 0-4 3-4 7a4 4 0 008 0c0-4-4-7-4-7z'/><path d='M8 9V5'/>
                  </svg>
                  Ingredients
                </span>
                <span
                  class='block h-5 w-5 shrink-0 text-on-surface-variant transition-transform duration-200 [[aria-expanded=true]_&]:rotate-180'
                  aria-hidden='true'
                >
                  <svg
                    viewBox='0 0 20 20'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.75'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  >
                    <path d='M5 7.5l5 5 5-5'/>
                  </svg>
                </span>
              </button>
              <div
                data-accordion-panel
                hidden
                class='prose prose-sm max-w-none pb-5 text-on-surface-variant'
              >
                {{ product.metafields.pet.ingredients.value }}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Shipping & Returns {%- endcomment -%}
          <div data-accordion>
            <button
              type='button'
              data-accordion-trigger
              aria-expanded='false'
              class='flex w-full items-center justify-between py-4 text-left text-sm font-semibold text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary'
            >
              <span class='flex items-center gap-2'>
                <span class='block h-4 w-4 shrink-0 text-on-surface-variant' aria-hidden='true'>
                  {%- render 'icon', icon: 'shipping' -%}
                </span>
                Shipping &amp; Returns
              </span>
              <span
                class='block h-5 w-5 shrink-0 text-on-surface-variant transition-transform duration-200 [[aria-expanded=true]_&]:rotate-180'
                aria-hidden='true'
              >
                <svg
                  viewBox='0 0 20 20'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.75'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                >
                  <path d='M5 7.5l5 5 5-5'/>
                </svg>
              </span>
            </button>
            <div
              data-accordion-panel
              hidden
              class='pb-5 text-sm leading-relaxed text-on-surface-variant'
            >
              <p>
                Free standard shipping on orders over $50. Orders placed before 3PM on weekdays ship the same day.
                Delivery typically takes 2–5 business days.
              </p>
              <p class='mt-2'>
                Not happy? We offer hassle-free returns within 30 days of delivery. Simply contact our team and we'll
                arrange a free return label.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ── Trust strip ── {%- endcomment -%}
    <div class='mt-12 grid grid-cols-1 gap-4 rounded-3xl bg-surface p-8 shadow-ambient sm:grid-cols-3'>
      <div class='flex items-start gap-4'>
        <span
          class='flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-medical-green text-primary'
          aria-hidden='true'
        >
          <span class='block h-6 w-6'>
            {%- render 'icon', icon: 'vet-approved' -%}
          </span>
        </span>
        <div>
          <p class='font-semibold text-on-surface'>Vet Approved</p>
          <p class='mt-0.5 text-sm text-on-surface-variant'>Every product reviewed by our in-house veterinary team.</p>
        </div>
      </div>
      <div class='flex items-start gap-4'>
        <span
          class='flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-medical-blue text-tertiary'
          aria-hidden='true'
        >
          <span class='block h-6 w-6'>
            {%- render 'icon', icon: 'shipping' -%}
          </span>
        </span>
        <div>
          <p class='font-semibold text-on-surface'>Free Shipping</p>
          <p class='mt-0.5 text-sm text-on-surface-variant'>On all orders over $50. Same-day dispatch before 3PM.</p>
        </div>
      </div>
      <div class='flex items-start gap-4'>
        <span
          class='flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-secondary/15 text-secondary'
          aria-hidden='true'
        >
          <span class='block h-6 w-6'>
            {%- render 'icon', icon: 'returns' -%}
          </span>
        </span>
        <div>
          <p class='font-semibold text-on-surface'>Easy Returns</p>
          <p class='mt-0.5 text-sm text-on-surface-variant'>30-day hassle-free returns. No questions asked.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} Variant data for client-side price/availability updates {%- endcomment -%}
<script id='product-variants-json' type='application/json'>
  [
    {%- for v in product.variants -%}
      {
        "id": {{ v.id }},
        "price": {{ v.price }},
        "compare_at_price": {{ v.compare_at_price | default: 0 }},
        "available": {{ v.available }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>

{%- render 'sticky-atc', product: product -%}

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Show order cutoff urgency message",
      "default": true
    },
    {
      "type": "header",
      "content": "Quick benefits"
    },
    {
      "type": "paragraph",
      "content": "Show up to 3 short product benefits near the Add to Cart button. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "placeholder": "e.g. Formulated by veterinary nutritionists"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "placeholder": "e.g. No artificial preservatives or fillers"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3",
      "placeholder": "e.g. Suitable for all life stages"
    }
  ]
}
{% endschema %}
