{%- if section.blocks.size > 0 -%}
  <section class='testimonials bg-surface {{ section.settings.padding }}'>
    <div class='mx-auto max-w-7xl px-6 lg:px-8'>
      {%- if section.settings.heading != blank -%}
        <div class='mb-16 text-center space-y-4'>
          <h2 class='font-display text-4xl font-extrabold text-primary'>{{ section.settings.heading }}</h2>
          <div class='flex justify-center gap-1 text-secondary' aria-label='5 out of 5 stars'>
            {%- for i in (1..5) -%}
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 20 20'
                fill='currentColor'
                class='h-5 w-5'
                aria-hidden='true'
              >
                <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' />
              </svg>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <ul class='grid grid-cols-1 gap-8 md:grid-cols-3' role='list'>
        {%- for block in section.blocks -%}
          <li
            class='flex flex-col bg-white p-10 rounded-[2.5rem] shadow-bubbly border border-primary/5'
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.quote != blank -%}
              <blockquote class='flex-1 text-on-surface-variant text-lg font-medium italic leading-relaxed mb-8'>
                &ldquo;{{ block.settings.quote }}&rdquo;
              </blockquote>
            {%- endif -%}

            <div class='flex items-center gap-4 mt-auto'>
              {%- if block.settings.author_image != blank -%}
                <div class='h-14 w-14 flex-shrink-0 overflow-hidden rounded-full border-2 border-primary/10'>
                  {{
                    block.settings.author_image
                    | image_url: width: 112
                    | image_tag:
                      width: 112,
                      height: 112,
                      loading: 'lazy',
                      class: 'h-full w-full object-cover',
                      alt: block.settings.author_name
                    | default: ''
                  }}
                </div>
              {%- else -%}
                <div
                  class='flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary text-sm font-bold border-2 border-primary/10'
                  aria-hidden='true'
                >
                  {{- block.settings.author_name | slice: 0, 1 | upcase -}}
                </div>
              {%- endif -%}

              <div>
                {%- if block.settings.author_name != blank -%}
                  <p class='font-bold text-primary'>{{ block.settings.author_name }}</p>
                {%- endif -%}
                {%- if block.settings.author_meta != blank -%}
                  <p class='text-xs font-bold text-on-surface-variant/60 uppercase'>{{ block.settings.author_meta }}</p>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Testimonials",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by Pets & Parents"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-24"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name"
        },
        {
          "type": "text",
          "id": "author_meta",
          "label": "Author meta",
          "info": "e.g. Owner of two rescue cats"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "The only clinic where Barnaby feels at home. The staff's care for animals is truly heartwarming.",
            "author_name": "Sarah Jenkins",
            "author_meta": "Owner of two rescue kittens"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Exquisite boutique products and world-class vets. They've helped Bella through so much with such grace.",
            "author_name": "Mark Thompson",
            "author_meta": "Labrador dad, since 2019"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Booking an appointment is seamless. I appreciate the transparency and the joyful energy of the clinic.",
            "author_name": "Elena Rodriguez",
            "author_meta": "Cat mum and online shopper"
          }
        }
      ]
    }
  ]
}
{% endschema %}
