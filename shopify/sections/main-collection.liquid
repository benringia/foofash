{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign active_filter_count = 0
  for filter in collection.filters
    assign active_filter_count = active_filter_count | plus: filter.active_values.size
  endfor
-%}

{%- paginate collection.products by section.settings.products_per_page -%}
  <section
    class='bg-surface-container-low'
    style='padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px'
  >
    {{- '<!-- Collection hero -->' -}}
    <div class='relative overflow-hidden bg-gradient-to-b from-[#f8faf8] to-white'>
      <div
        class='pointer-events-none absolute right-0 top-0 h-64 w-96 rounded-full bg-primary/5 blur-3xl'
        aria-hidden='true'
      ></div>
      <div
        class='pointer-events-none absolute bottom-0 left-0 h-48 w-80 rounded-full bg-secondary/5 blur-3xl'
        aria-hidden='true'
      ></div>

      {%- if collection.image != blank -%}
        {%- assign img_alt = collection.image.alt | default: collection.title -%}
        <div class='pointer-events-none absolute inset-0' aria-hidden='true'>
          {{
            collection.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              width: 1400,
              height: 560,
              class: 'h-full w-full object-cover opacity-10',
              alt: ''
          }}
        </div>
      {%- endif -%}

      <div class='relative mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-10'>
        <p class='mb-2 text-xs font-medium uppercase tracking-widest text-primary/50'>Shop</p>

        <h1 class='text-4xl font-extrabold leading-tight tracking-tight text-on-surface lg:text-5xl'>
          {{ collection.title }}
        </h1>

        {%- if collection.description != blank -%}
          <p class='mt-3 max-w-2xl text-base leading-relaxed text-on-surface-variant'>
            {{ collection.description }}
          </p>
        {%- endif -%}

        <div
          class='my-4 h-px bg-gradient-to-r from-transparent via-on-surface/10 to-transparent'
          role='separator'
        ></div>

        <div class='flex flex-wrap items-center gap-3'>
          <span class='inline-flex items-center rounded-full border border-gray-100 bg-white/80 px-3 py-1.5 text-xs font-semibold text-on-surface-variant'>
            {{ paginate.items }}
            {%- if paginate.items == 1 -%}&nbsp;product{%- else -%}&nbsp;products{%- endif -%}
          </span>

          {%- if section.settings.show_trust_strip -%}
            <span class='flex items-center gap-1.5 rounded-full border border-gray-100 bg-white/80 px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'vet-approved' -%}
              </span>
              {{ section.settings.trust_badge_1 | default: 'Vet Approved Picks' }}
            </span>
            <span class='flex items-center gap-1.5 rounded-full border border-gray-100 bg-white/80 px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'shipping' -%}
              </span>
              {{ section.settings.trust_badge_2 }}
            </span>
            <span class='flex items-center gap-1.5 rounded-full border border-gray-100 bg-white/80 px-3 py-1.5 text-xs font-semibold text-on-surface'>
              <span class='h-3.5 w-3.5 shrink-0 text-primary' aria-hidden='true'>
                {%- render 'icon', icon: 'returns' -%}
              </span>
              {{ section.settings.trust_badge_3 }}
            </span>
          {%- endif -%}
        </div>
      </div>
    </div>

    {{- '<!-- Sticky controls bar -->' -}}
    <div class='sticky top-[var(--header-height)] z-10 border-b border-on-surface/6 bg-surface/95 backdrop-blur-sm'>
      <div class='mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8'>
        {{- '<!-- Left: filter button + count + active pills -->' -}}
        <div class='flex min-w-0 flex-1 items-center gap-3'>
          {%- if collection.filters.size > 0 -%}
            <button
              type='button'
              data-filter-open
              aria-expanded='false'
              aria-controls='filter-panel'
              class='inline-flex shrink-0 items-center gap-2 rounded-2xl bg-surface px-4 py-2 text-sm font-semibold text-on-surface shadow-ambient transition-shadow hover:shadow-bubbly focus:outline-none focus:ring-2 focus:ring-primary lg:hidden'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='16'
                height='16'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
                focusable='false'
              >
                <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/>
              </svg>
              Filters
              {%- if active_filter_count > 0 -%}
                <span class='flex h-5 w-5 items-center justify-center rounded-full bg-primary text-xs font-bold text-on-primary'>
                  {{- active_filter_count -}}
                </span>
              {%- endif -%}
            </button>
          {%- endif -%}

          {%- if active_filter_count > 0 -%}
            <div class='flex min-w-0 items-center gap-2 overflow-x-auto'>
              {%- for filter in collection.filters -%}
                {%- for value in filter.active_values -%}
                  <a
                    href='{{ value.url_to_remove }}'
                    class='inline-flex shrink-0 items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary transition-colors hover:bg-primary/15'
                  >
                    {{ filter.label }}: {{ value.label }}
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      width='10'
                      height='10'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2.5'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      aria-hidden='true'
                      focusable='false'
                    >
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </a>
                {%- endfor -%}
              {%- endfor -%}
              <a
                href='{{ collection.url }}'
                class='shrink-0 text-xs font-semibold text-primary transition-colors hover:text-primary-dim'
              >
                Clear all
              </a>
            </div>
          {%- endif -%}
        </div>

        {{- '<!-- Right: sort control -->' -}}
        {%- if collection.sort_options.size > 0 -%}
          <div class='flex shrink-0 items-center gap-2 rounded-2xl bg-surface px-4 py-2 shadow-ambient'>
            <label
              for='sort-select'
              class='whitespace-nowrap text-xs font-semibold uppercase tracking-wide text-on-surface-variant'
            >
              Sort by
            </label>
            <select
              id='sort-select'
              data-sort-select
              aria-label='Sort products'
              class='cursor-pointer bg-transparent text-sm font-semibold text-on-surface focus:outline-none'
            >
              {%- for option in collection.sort_options -%}
                <option
                  value='{{ option.value }}'
                  {%- if option.value == sort_by -%}
                    selected
                  {%- endif -%}
                >
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}
      </div>
    </div>

    {{- '<!-- Main layout: sidebar + product grid -->' -}}
    <div class='mx-auto max-w-7xl px-4 pt-8 sm:px-6 lg:px-8'>
      <div class='flex gap-8 lg:gap-10'>
        {{- '<!-- Desktop sidebar -->' -}}
        {%- if collection.filters.size > 0 -%}
          <aside class='hidden w-64 flex-none lg:block' aria-label='Product filters'>
            <div class='sticky top-40 max-h-[calc(100vh-10.5rem)] overflow-y-auto space-y-4 pb-4'>
              <p class='mb-1 text-xs font-bold uppercase tracking-wider text-primary/70'>Refine</p>
              {%- for filter in collection.filters -%}
                {%- render 'filter-group', filter: filter -%}
              {%- endfor -%}
              {%- if active_filter_count > 0 -%}
                <a
                  href='{{ collection.url }}'
                  class='block rounded-xl bg-primary/10 py-2 text-center text-sm font-semibold text-primary transition-colors hover:bg-primary/15'
                >
                  Clear all filters
                </a>
              {%- endif -%}
            </div>
          </aside>
        {%- endif -%}

        {{- '<!-- Product area -->' -}}
        <div class='min-w-0 flex-1'>
          {%- if collection.products.size > 0 -%}
            <ul
              class='grid grid-cols-2 gap-6 sm:gap-8 md:grid-cols-3'
              role='list'
            >
              {%- for product in collection.products -%}
                <li>
                  {%- render 'product-card',
                    product: product,
                    badge_vet_label: settings.badge_vet_label,
                    badge_sale_label: settings.badge_sale_label
                  -%}
                </li>
              {%- endfor -%}
            </ul>

            {{- '<!-- Pagination -->' -}}
            {%- if paginate.pages > 1 -%}
              <nav
                aria-label='Pagination'
                class='mt-16 flex items-center justify-center gap-2'
              >
                {%- if paginate.previous -%}
                  <a
                    href='{{ paginate.previous.url }}'
                    aria-label='Previous page'
                    class='inline-flex h-10 items-center gap-2 rounded-2xl bg-surface px-4 text-sm font-semibold text-on-surface shadow-ambient transition-shadow hover:shadow-bubbly focus:outline-none focus:ring-2 focus:ring-primary'
                  >
                    ← Previous
                  </a>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a
                      href='{{ part.url }}'
                      class='inline-flex h-10 w-10 items-center justify-center rounded-xl bg-surface text-sm font-semibold text-on-surface shadow-ambient transition-shadow hover:shadow-bubbly focus:outline-none focus:ring-2 focus:ring-primary'
                    >
                      {{ part.title }}
                    </a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span class='inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary-gradient text-sm font-bold text-on-primary'>
                      {{- part.title -}}
                    </span>
                  {%- else -%}
                    <span class='inline-flex h-10 w-10 items-center justify-center text-sm text-on-surface-variant'>
                      {{- part.title -}}
                    </span>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <a
                    href='{{ paginate.next.url }}'
                    aria-label='Next page'
                    class='inline-flex h-10 items-center gap-2 rounded-2xl bg-surface px-4 text-sm font-semibold text-on-surface shadow-ambient transition-shadow hover:shadow-bubbly focus:outline-none focus:ring-2 focus:ring-primary'
                  >
                    Next →
                  </a>
                {%- endif -%}
              </nav>
            {%- endif -%}

          {%- else -%}
            {{- '<!-- Empty state -->' -}}
            <div class='flex flex-col items-center gap-6 rounded-3xl bg-surface px-8 py-20 text-center shadow-ambient'>
              <div
                class='flex h-20 w-20 items-center justify-center rounded-full bg-primary/10 text-primary ring-1 ring-primary/10'
                aria-hidden='true'
              >
                <span class='block h-10 w-10'>
                  {%- render 'icon', icon: 'paw' -%}
                </span>
              </div>
              <div>
                <p class='text-xl font-bold text-on-surface'>No products found</p>
                {%- if active_filter_count > 0 -%}
                  <p class='mx-auto mt-2 max-w-xs text-sm text-on-surface-variant'>
                    Try removing some filters to discover more products.
                  </p>
                  <a
                    href='{{ collection.url }}'
                    class='mt-6 inline-block rounded-2xl bg-primary-gradient px-6 py-3 text-sm font-bold text-on-primary transition-transform hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
                  >
                    Clear all filters
                  </a>
                {%- else -%}
                  <p class='mt-2 text-sm text-on-surface-variant'>Check back soon — new products are on their way.</p>
                  <a
                    href='/collections/all'
                    class='mt-6 inline-block rounded-2xl bg-surface px-6 py-3 text-sm font-semibold text-on-surface shadow-ambient transition-shadow hover:shadow-bubbly focus:outline-none focus:ring-2 focus:ring-primary'
                  >
                    Browse all products
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {{- '<!-- Mobile filter panel (off-canvas) -->' -}}
  {%- if collection.filters.size > 0 -%}
    <div
      data-filter-overlay
      class='fixed inset-0 z-40 hidden bg-black/50'
      aria-hidden='true'
    ></div>

    <div
      id='filter-panel'
      data-filter-panel
      role='dialog'
      aria-modal='true'
      aria-label='Product filters'
      class='fixed inset-y-0 left-0 z-50 w-80 max-w-full -translate-x-full overflow-y-auto bg-surface p-6 shadow-bubbly-lg transition-transform duration-300 ease-in-out lg:hidden'
    >
      <div class='mb-6 flex items-center justify-between'>
        <h2 class='text-xl font-extrabold text-on-surface'>Filters</h2>
        <button
          type='button'
          data-filter-close
          aria-label='Close filters'
          class='flex h-10 w-10 items-center justify-center rounded-2xl bg-surface-container-low text-on-surface transition-colors hover:bg-primary/10 focus:outline-none focus:ring-2 focus:ring-primary'
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='20'
            height='20'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            focusable='false'
          >
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div class='space-y-3'>
        {%- for filter in collection.filters -%}
          {%- render 'filter-group', filter: filter -%}
        {%- endfor -%}
      </div>

      {%- if active_filter_count > 0 -%}
        <a
          href='{{ collection.url }}'
          class='mt-6 block rounded-xl bg-primary/10 py-3 text-center text-sm font-semibold text-primary transition-colors hover:bg-primary/15'
        >
          Clear all filters
        </a>
      {%- endif -%}

      <div class='sticky bottom-0 mt-6 bg-surface pb-0 pt-2'>
        <button
          type='button'
          data-filter-close
          class='w-full rounded-2xl bg-primary-gradient py-3 text-sm font-bold text-on-primary transition-transform hover:scale-[1.01] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
        >
          Done
        </button>
      </div>
    </div>
  {%- endif -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show trust badges in header",
      "default": true
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "text",
      "id": "trust_badge_1",
      "label": "Badge 1 text",
      "default": "Vet Approved Picks"
    },
    {
      "type": "text",
      "id": "trust_badge_2",
      "label": "Badge 2 text",
      "default": "Free shipping over $50"
    },
    {
      "type": "text",
      "id": "trust_badge_3",
      "label": "Badge 3 text",
      "default": "Easy 30-day returns"
    }
  ]
}
{% endschema %}
