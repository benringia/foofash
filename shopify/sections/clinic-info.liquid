<div class='clinic-info {{ section.settings.padding }} px-6 lg:px-8'>
  <section class='mx-auto max-w-7xl overflow-hidden rounded-[4rem] bg-primary-dim'>
    <div class='grid grid-cols-1 lg:grid-cols-2'>
      {%- comment -%} Left: text content {%- endcomment -%}
      <div class='flex flex-col justify-center gap-8 p-12 lg:p-20'>
        {%- if section.settings.eyebrow != blank -%}
          <div class='inline-block self-start bg-white/10 px-4 py-1.5 rounded-full border border-white/20'>
            <span class='text-xs font-black tracking-widest uppercase text-secondary'>
              {{- section.settings.eyebrow -}}
            </span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class='font-display text-4xl font-extrabold text-white leading-tight lg:text-5xl'>
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class='text-white/80 text-xl font-medium leading-relaxed'>{{ section.settings.subheading }}</p>
        {%- endif -%}

        <div class='flex flex-col gap-6 pt-4'>
          {%- if section.settings.address != blank -%}
            <div class='flex items-start gap-5'>
              <div
                class='w-12 h-12 flex-shrink-0 bg-white/10 rounded-2xl flex items-center justify-center text-secondary'
                aria-hidden='true'
              >
                <span class='h-6 w-6'>{%- render 'icon', icon: 'location' -%}</span>
              </div>
              <div>
                <p class='font-bold text-lg text-white'>{{ section.settings.address | split: ',' | first }}</p>
                <p class='text-white/60'>{{ section.settings.address | split: ',' | shift | join: ',' }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <div class='flex items-start gap-5'>
              <div
                class='w-12 h-12 flex-shrink-0 bg-white/10 rounded-2xl flex items-center justify-center text-secondary'
                aria-hidden='true'
              >
                <span class='h-6 w-6'>{%- render 'icon', icon: 'clock' -%}</span>
              </div>
              <div>
                {%- assign hours_lines = section.settings.hours | split: '\n' -%}
                <p class='font-bold text-lg text-white'>{{ hours_lines[0] }}</p>
                {%- if hours_lines[1] != blank -%}
                  <p class='text-white/60'>{{ hours_lines[1] }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_label != blank -%}
          <div>
            <a
              href='{{ section.settings.cta_link | default: '#' }}'
              class='inline-block rounded-full bg-secondary px-10 py-5 font-bold text-lg text-white shadow-xl shadow-secondary/20 transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-primary-dim'
            >
              {{ section.settings.cta_label }}
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: image in white rounded card {%- endcomment -%}
      <div class='flex items-center justify-center p-8'>
        <div class='relative w-full min-h-[300px] lg:h-[500px] rounded-[3rem] overflow-hidden shadow-2xl'>
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_tag:
                loading: 'lazy',
                width: 800,
                height: 700,
                class: 'h-full w-full object-cover',
                alt: section.settings.image.alt
              | default: section.settings.heading
            }}
          {%- else -%}
            <div class='flex h-full w-full items-center justify-center bg-primary'>
              <span class='h-24 w-24 text-white/20' aria-hidden='true'>
                {%- render 'icon', icon: 'paw' -%}
              </span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Clinic Info",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Flagship Location"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit Our Modern Wellness Center"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience a stress-free environment where every detail is designed for your pet's comfort and clinical excellence."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "123 Petal Lane, Furry Heights, New York, NY 10011"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Hours",
      "default": "Open 24/7 for Emergencies\nRegular clinic: 8AM – 8PM"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Get Directions"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-24"
    }
  ],
  "presets": [
    {
      "name": "Clinic Info"
    }
  ]
}
{% endschema %}
