<div class='clinic-info {{ section.settings.padding }} px-4 lg:px-8'>
  <section class='mx-auto max-w-7xl overflow-hidden rounded-4xl bg-primary'>
    <div class='grid grid-cols-1 lg:grid-cols-2'>
      {%- comment -%} Left: text content {%- endcomment -%}
      <div class='flex flex-col justify-center gap-6 p-10 lg:p-16'>
        {%- if section.settings.eyebrow != blank -%}
          <span class='inline-block self-start rounded-full bg-secondary/20 px-3 py-1 text-xs font-semibold text-secondary'>
            {{ section.settings.eyebrow }}
          </span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class='font-display text-3xl font-bold text-white lg:text-4xl'>{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class='text-base leading-relaxed text-white/70'>{{ section.settings.subheading }}</p>
        {%- endif -%}

        <div class='flex flex-col gap-4'>
          {%- if section.settings.address != blank -%}
            <div class='flex items-start gap-3'>
              <span class='mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-secondary' aria-hidden='true'></span>
              <p class='text-sm text-white/80'>{{ section.settings.address }}</p>
            </div>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <div class='flex items-start gap-3'>
              <span class='mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-secondary' aria-hidden='true'></span>
              <p class='text-sm text-white/80'>{{ section.settings.hours | newline_to_br }}</p>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_label != blank -%}
          <div>
            <a
              href='{{ section.settings.cta_link | default: '#' }}'
              class='inline-block rounded-full bg-secondary px-8 py-3 font-semibold text-white shadow-ambient transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-primary'
            >
              {{ section.settings.cta_label }}
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: image {%- endcomment -%}
      {%- if section.settings.image != blank -%}
        <div class='relative min-h-[300px] lg:min-h-0'>
          {{
            section.settings.image
            | image_tag:
              loading: 'lazy',
              width: 800,
              height: 700,
              class: 'h-full w-full object-cover',
              alt: section.settings.image.alt
            | default: section.settings.heading
          }}
        </div>
      {%- else -%}
        <div class='flex min-h-[300px] items-center justify-center bg-primary-dim lg:min-h-0'>
          <span class='h-24 w-24 text-white/20' aria-hidden='true'>
            {%- render 'icon', icon: 'paw' -%}
          </span>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Clinic Info",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Flagship Location"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit Our Modern Wellness Center"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience a stress-free environment where every detail is designed for your pet's comfort and clinical excellence."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "123 Petal Lane, Furry Heights, New York, NY 10011"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Hours",
      "default": "Open 24/7 for Emergencies\nRegular clinic: 8AM – 8PM"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Get Directions"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-16"
    }
  ],
  "presets": [
    {
      "name": "Clinic Info"
    }
  ]
}
{% endschema %}
