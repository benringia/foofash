<section class='hero-banner hero-gradient -mt-24 relative flex min-h-screen items-center overflow-hidden'>
  {%- comment -%} Background blobs — larger and more saturated for visibility {%- endcomment -%}
  <div
    class='pointer-events-none absolute -left-48 -top-20 h-[600px] w-[600px] rounded-full bg-primary/10 blur-3xl'
    aria-hidden='true'
  ></div>
  <div
    class='pointer-events-none absolute -right-48 bottom-0 h-[500px] w-[500px] rounded-full bg-secondary/20 blur-3xl'
    aria-hidden='true'
  ></div>
  <div
    class='pointer-events-none absolute right-1/3 top-10 h-80 w-80 rounded-full bg-medical-blue blur-2xl'
    aria-hidden='true'
  ></div>

  <div class='relative z-10 mx-auto w-full max-w-7xl px-6'>
    <div class='grid grid-cols-1 items-center gap-16 lg:grid-cols-2'>
      {%- comment -%} Left: text content {%- endcomment -%}
      <div class='flex flex-col gap-10 text-center lg:text-left'>
        {%- if section.settings.eyebrow != blank -%}
          <div
            class='inline-flex items-center gap-3 self-center rounded-full border border-primary/5 bg-white px-5 py-2 shadow-bubbly lg:self-start'
          >
            <span class='flex h-2 w-2 animate-pulse rounded-full bg-secondary' aria-hidden='true'></span>
            <span class='text-xs font-bold uppercase tracking-widest text-primary'>
              {{- section.settings.eyebrow -}}
            </span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class='font-display text-6xl font-extrabold leading-[1.05] tracking-tight text-primary lg:text-7xl'>
            {{ section.settings.heading }}
            {%- if section.settings.heading_accent != blank -%}
              <br>
              <span class='text-secondary'>{{ section.settings.heading_accent }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class='mx-auto max-w-lg text-xl font-medium leading-relaxed text-on-surface-variant lg:mx-0'>
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.primary_cta_label != blank or section.settings.secondary_cta_label != blank -%}
          <div class='flex flex-wrap items-center justify-center gap-4 lg:justify-start'>
            {%- if section.settings.primary_cta_label != blank -%}
              <a
                href='{{ section.settings.primary_cta_link | default: '#' }}'
                class='inline-block cursor-pointer rounded-full bg-primary px-10 py-5 text-lg font-bold text-white shadow-bubbly-lg transition-all hover:-translate-y-1 hover:bg-primary-dim hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
              >
                {{ section.settings.primary_cta_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.secondary_cta_label != blank -%}
              <a
                href='{{ section.settings.secondary_cta_link | default: '#' }}'
                class='inline-block cursor-pointer rounded-full border-2 border-primary/10 bg-white px-10 py-5 text-lg font-bold text-primary transition-all hover:border-primary/20 hover:bg-surface-container focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2'
              >
                {{ section.settings.secondary_cta_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.trust_label != blank -%}
          <div class='flex items-center justify-center gap-8 pt-4 lg:justify-start'>
            <div class='flex -space-x-4' aria-hidden='true'>
              <div class='flex h-12 w-12 items-center justify-center rounded-full border-4 border-white bg-medical-green'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'vet-approved' -%}</span>
              </div>
              <div class='flex h-12 w-12 items-center justify-center rounded-full border-4 border-white bg-medical-blue'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'stethoscope' -%}</span>
              </div>
              <div class='flex h-12 w-12 items-center justify-center rounded-full border-4 border-white bg-surface-container-low'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'paw' -%}</span>
              </div>
            </div>
            <p class='text-sm font-semibold text-on-surface-variant'>{{ section.settings.trust_label }}</p>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: layered image with depth {%- endcomment -%}
      <div class='flex items-center justify-center py-8 lg:py-0 lg:pl-4'>
        {%- comment -%} Outer container — positions floating stat cards relative to image {%- endcomment -%}
        <div class='relative w-full max-w-[520px]'>
          {%- comment -%} Depth layer 2 (back-most) — offset orange frame {%- endcomment -%}
          <div
            class='absolute inset-0 translate-x-5 translate-y-5 rounded-3xl bg-secondary/25'
            aria-hidden='true'
          ></div>
          {%- comment -%} Depth layer 1 — offset green frame {%- endcomment -%}
          <div
            class='absolute inset-0 -translate-x-2 translate-y-3 rounded-3xl bg-primary/10'
            aria-hidden='true'
          ></div>

          {%- comment -%} Main image card {%- endcomment -%}
          {%- if section.settings.image != blank -%}
            <div class='group relative z-10 overflow-hidden rounded-3xl shadow-bubbly-lg ring-1 ring-primary/5'>
              {{
                section.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  width: 800,
                  height: 700,
                  class: 'w-full h-[300px] sm:h-[400px] lg:h-[520px] object-cover transition-transform duration-700 group-hover:scale-[1.03]',
                  alt: section.settings.image.alt
                | default: section.settings.heading
              }}
            </div>
          {%- else -%}
            <div class='relative z-10 flex aspect-[4/3] w-full items-center justify-center rounded-3xl bg-surface-container shadow-bubbly-lg'>
              <span class='h-32 w-32 text-primary/20' aria-hidden='true'>
                {%- render 'icon', icon: 'paw' -%}
              </span>
            </div>
          {%- endif -%}

          {%- comment -%} Floating stat card — top left {%- endcomment -%}
          {%- if section.settings.stat_1_value != blank -%}
            <div
              class='absolute -left-6 top-8 z-20 flex items-center gap-3 rounded-2xl bg-white px-4 py-3 shadow-bubbly ring-1 ring-primary/5'
              aria-label='{{ section.settings.stat_1_label }}: {{ section.settings.stat_1_value }}'
            >
              <span class='text-xl leading-none' aria-hidden='true'>⭐</span>
              <div>
                <p class='text-sm font-black text-primary'>{{ section.settings.stat_1_value }}</p>
                <p class='text-xs text-on-surface-variant'>{{ section.settings.stat_1_label }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Floating stat card — bottom right {%- endcomment -%}
          {%- if section.settings.stat_2_value != blank -%}
            <div
              class='absolute -right-6 bottom-8 z-20 flex items-center gap-3 rounded-2xl bg-white px-4 py-3 shadow-bubbly ring-1 ring-primary/5'
              aria-label='{{ section.settings.stat_2_label }}: {{ section.settings.stat_2_value }}'
            >
              <span class='text-xl leading-none' aria-hidden='true'>🐾</span>
              <div>
                <p class='text-sm font-black text-primary'>{{ section.settings.stat_2_value }}</p>
                <p class='text-xs text-on-surface-variant'>{{ section.settings.stat_2_label }}</p>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Optional trust signal above the heading",
      "default": "Premium Clinical Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Happy Paws,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent line",
      "info": "Rendered below the main heading in the secondary (orange) colour",
      "default": "Healthy Hearts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your pet's best life starts here. Combining world-class veterinary expertise with premium boutique care for every furry family member."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "trust_label",
      "label": "Trust indicator text",
      "default": "Trusted by 5,000+ Pet Parents"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Floating stat cards"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Average Rating"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "5,000+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Happy Pets"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
