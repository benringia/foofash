<section class='hero-banner {{ section.settings.padding }} bg-surface'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='grid grid-cols-1 items-center gap-12 lg:grid-cols-2'>
      {%- comment -%} Left: text content {%- endcomment -%}
      <div class='flex flex-col gap-6'>
        {%- if section.settings.eyebrow != blank -%}
          <p class='text-xs font-semibold uppercase tracking-[0.1em] text-primary'>
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class='font-display text-5xl font-extrabold leading-tight text-on-surface lg:text-6xl'>
            {{ section.settings.heading }}
            {%- if section.settings.heading_accent != blank -%}
              <span class='text-secondary'>{{ section.settings.heading_accent }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class='font-body text-lg leading-relaxed text-on-surface/70'>
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.primary_cta_label != blank -%}
          <div class='flex flex-wrap items-center gap-3'>
            <a
              href='{{ section.settings.primary_cta_link | default: '#' }}'
              class='inline-block rounded-full bg-primary-gradient px-8 py-3 font-semibold text-white shadow-ambient transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
            >
              {{ section.settings.primary_cta_label }}
            </a>

            {%- if section.settings.secondary_cta_label != blank -%}
              <a
                href='{{ section.settings.secondary_cta_link | default: '#' }}'
                class='inline-block rounded-full bg-surface-high px-8 py-3 font-semibold text-on-surface transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-on-surface/20 focus:ring-offset-2'
              >
                {{ section.settings.secondary_cta_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.trust_label != blank -%}
          <p class='text-sm text-on-surface/50'>{{ section.settings.trust_label }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Right: image with blob background {%- endcomment -%}
      {%- if section.settings.image != blank -%}
        <div class='relative flex items-center justify-center'>
          <div
            class='absolute inset-0 -z-0 scale-110 opacity-30'
            aria-hidden='true'
          >
            <svg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg' class='h-full w-full'>
              <path
                fill='#336f54'
                d='M320.5,280.5Q270,361,180,360.5Q90,360,50,280Q10,200,55,120Q100,40,185,35Q270,30,322.5,115Q375,200,320.5,280.5Z'
              />
            </svg>
          </div>
          <div class='relative z-10 overflow-hidden rounded-3xl shadow-ambient'>
            {{
              section.settings.image
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                width: 800,
                height: 700,
                class: 'h-full w-full object-cover',
                alt: section.settings.image.alt
              | default: section.settings.heading
            }}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Optional trust signal above the heading",
      "default": "Premium Clinical Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Happy Paws,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent line",
      "info": "Rendered below the main heading in the secondary (orange) colour",
      "default": "Healthy Hearts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your pet's best life starts here. Combining world-class veterinary expertise with premium boutique care for every furry family member."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "trust_label",
      "label": "Trust indicator text",
      "default": "Trusted by 5,000+ Pet Parents"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Section padding",
      "options": [
        { "value": "py-8", "label": "Small" },
        { "value": "py-16", "label": "Medium" },
        { "value": "py-24", "label": "Large" }
      ],
      "default": "py-16"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
