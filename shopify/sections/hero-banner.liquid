<section class='hero-banner hero-gradient relative flex min-h-screen items-center pt-20'>
  <div class='mx-auto max-w-7xl px-6 w-full'>
    <div class='grid grid-cols-1 items-center gap-12 lg:grid-cols-2'>
      {%- comment -%} Left: text content {%- endcomment -%}
      <div class='flex flex-col gap-10 z-10 text-center lg:text-left'>
        {%- if section.settings.eyebrow != blank -%}
          <div class='inline-flex items-center gap-3 self-center lg:self-start bg-white px-5 py-2 rounded-full shadow-bubbly border border-primary/5'>
            <span class='flex h-2 w-2 rounded-full bg-secondary animate-pulse' aria-hidden='true'></span>
            <span class='text-primary font-bold text-xs uppercase tracking-widest'>{{ section.settings.eyebrow }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class='font-display text-6xl font-extrabold text-primary leading-[1.05] tracking-tight lg:text-8xl'>
            {{ section.settings.heading }}
            {%- if section.settings.heading_accent != blank -%}
              <br>
              <span class='text-secondary'>{{ section.settings.heading_accent }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class='text-xl text-on-surface-variant max-w-lg leading-relaxed font-medium mx-auto lg:mx-0'>
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.primary_cta_label != blank or section.settings.secondary_cta_label != blank -%}
          <div class='flex flex-wrap items-center gap-4 justify-center lg:justify-start'>
            {%- if section.settings.primary_cta_label != blank -%}
              <a
                href='{{ section.settings.primary_cta_link | default: '#' }}'
                class='inline-block cursor-pointer rounded-full bg-primary px-10 py-5 font-bold text-lg text-white shadow-bubbly-lg transition-all hover:bg-primary-dim hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
              >
                {{ section.settings.primary_cta_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.secondary_cta_label != blank -%}
              <a
                href='{{ section.settings.secondary_cta_link | default: '#' }}'
                class='inline-block cursor-pointer rounded-full bg-white text-primary border-2 border-primary/10 px-10 py-5 font-bold text-lg transition-all hover:bg-surface-container focus:outline-none focus:ring-2 focus:ring-primary/20 focus:ring-offset-2'
              >
                {{ section.settings.secondary_cta_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.trust_label != blank -%}
          <div class='flex items-center gap-8 justify-center lg:justify-start pt-4'>
            <div class='flex -space-x-4' aria-hidden='true'>
              <div class='w-12 h-12 rounded-full border-4 border-white bg-medical-green flex items-center justify-center'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'vet-approved' -%}</span>
              </div>
              <div class='w-12 h-12 rounded-full border-4 border-white bg-medical-blue flex items-center justify-center'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'stethoscope' -%}</span>
              </div>
              <div class='w-12 h-12 rounded-full border-4 border-white bg-surface-container-low flex items-center justify-center'>
                <span class='h-5 w-5 text-primary'>{%- render 'icon', icon: 'paw' -%}</span>
              </div>
            </div>
            <p class='text-sm font-semibold text-on-surface-variant'>{{ section.settings.trust_label }}</p>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: image {%- endcomment -%}
      <div class='relative flex items-center justify-center'>
        <div class='absolute w-[120%] h-[120%] bg-white/40 blur-3xl rounded-full' aria-hidden='true'></div>
        {%- if section.settings.image != blank -%}
          <div class='relative z-10 w-full max-w-[700px]'>
            {{
              section.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                width: 800,
                height: 700,
                class: 'w-full h-auto pointer-events-none',
                alt: section.settings.image.alt
              | default: section.settings.heading
            }}
          </div>
        {%- else -%}
          <div class='relative z-10 flex items-center justify-center py-16'>
            <div class='absolute inset-0 scale-110 opacity-20' aria-hidden='true'>
              <svg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg' class='h-full w-full'>
                <path
                  fill='#2D6A4F'
                  d='M320.5,280.5Q270,361,180,360.5Q90,360,50,280Q10,200,55,120Q100,40,185,35Q270,30,322.5,115Q375,200,320.5,280.5Z'
                />
              </svg>
            </div>
            <span class='relative z-10 h-40 w-40 text-primary/30' aria-hidden='true'>
              {%- render 'icon', icon: 'paw' -%}
            </span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Optional trust signal above the heading",
      "default": "Premium Clinical Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Happy Paws,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent line",
      "info": "Rendered below the main heading in the secondary (orange) colour",
      "default": "Healthy Hearts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your pet's best life starts here. Combining world-class veterinary expertise with premium boutique care for every furry family member."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "trust_label",
      "label": "Trust indicator text",
      "default": "Trusted by 5,000+ Pet Parents"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
