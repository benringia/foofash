{%- comment -%}
  Reusable product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<article class='product-card group flex flex-col'>
  <a href='{{ product.url }}' class='flex flex-col flex-1 gap-3' aria-label='{{ product.title }}'>
    <div class='relative aspect-square overflow-hidden rounded-lg bg-gray-100'>
      <button
        type='button'
        data-quick-view-trigger
        data-product-handle='{{ product.handle }}'
        aria-label='Quick view {{ product.title }}'
        class='absolute bottom-2 left-1/2 z-10 -translate-x-1/2 translate-y-2 rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-gray-800 opacity-0 shadow transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-green-500'
      >
        Quick view
      </button>
      {%- if product.featured_image != blank -%}
        {{
          product.featured_image
          | image_tag:
            loading: 'lazy',
            width: 600,
            height: 600,
            class: 'h-full w-full object-cover transition-transform duration-300 group-hover:scale-105',
            alt: product.featured_image.alt
          | default: product.title
        }}
      {%- else -%}
        <div class='flex h-full w-full items-center justify-center text-gray-300' aria-hidden='true'>
          {%- render 'icon', icon: 'paw' -%}
        </div>
      {%- endif -%}
    </div>

    <div class='flex flex-col gap-1 px-1'>
      <p class='line-clamp-2 text-sm font-medium text-gray-800 group-hover:text-green-700'>
        {{ product.title }}
      </p>
      {%- render 'price', product: product -%}
    </div>
  </a>
</article>
