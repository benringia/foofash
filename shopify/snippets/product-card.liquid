{%- comment -%}
  Reusable product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign badge_sale = false
  if product.compare_at_price > product.price
    assign badge_sale = true
  endif
  assign badge_vet = false
  if product.metafields.pet.vet_approved.value == true
    assign badge_vet = true
  endif
  assign product_subtitle = product.type
  if product_subtitle == blank
    assign product_subtitle = product.description | strip_html | truncatewords: 8
  endif
  assign card_variant = product.selected_or_first_available_variant
  assign low_stock = false
  assign low_stock_qty = 0
  if card_variant
    if card_variant.inventory_management != blank and card_variant.inventory_policy == 'deny'
      assign low_stock_qty = card_variant.inventory_quantity
      if low_stock_qty > 0 and low_stock_qty <= 5
        assign low_stock = true
      endif
    endif
  endif
-%}

<article class='product-card group relative overflow-hidden rounded-3xl bg-surface shadow-ambient transition-all duration-300 hover:-translate-y-1 hover:shadow-bubbly'>
  {{- '<!-- Image container -->' -}}
  <div class='relative aspect-square overflow-hidden bg-surface-container-low'>
    {%- if product.featured_image != blank -%}
      {%- assign card_img_alt = product.featured_image.alt | default: product.title -%}
      <a href='{{ product.url }}' tabindex='-1' aria-hidden='true' class='block h-full w-full'>
        {{
          product.featured_image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            width: 600,
            height: 600,
            class: 'h-full w-full object-cover transition-transform duration-700 group-hover:scale-105',
            alt: card_img_alt
        }}
      </a>
    {%- else -%}
      <div class='flex h-full w-full items-center justify-center text-on-surface/20' aria-hidden='true'>
        {%- render 'icon', icon: 'paw' -%}
      </div>
    {%- endif -%}

    {{- '<!-- Badges -->' -}}
    {%- if badge_vet or badge_sale or low_stock -%}
      <div class='absolute left-3 top-3 z-10 flex flex-col gap-1'>
        {%- if badge_vet -%}
          <span class='rounded-full bg-primary/90 px-2 py-0.5 text-xs font-bold leading-snug text-white'>
            {{ badge_vet_label | default: 'Vet Approved' }}
          </span>
        {%- endif -%}
        {%- if badge_sale -%}
          <span class='rounded-full bg-secondary px-2 py-0.5 text-xs font-bold leading-snug text-white'>
            {{ badge_sale_label | default: 'Sale' }}
          </span>
        {%- endif -%}
        {%- if low_stock -%}
          <span class='rounded-full bg-secondary/90 px-2 py-0.5 text-xs font-bold leading-snug text-white'>
            Low Stock
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {{- '<!-- Sold out overlay -->' -}}
    {%- unless product.available -%}
      <div class='absolute inset-0 flex items-center justify-center bg-surface/60'>
        <span class='rounded-full bg-on-surface/80 px-3 py-1 text-xs font-bold text-surface'>Sold Out</span>
      </div>
    {%- endunless -%}

    {{- '<!-- Hover overlay: gradient + Quick view -->' -}}
    <div
      class='pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity duration-200 group-hover:opacity-100'
      aria-hidden='true'
    ></div>
    <button
      type='button'
      data-quick-view-trigger
      data-product-handle='{{ product.handle }}'
      aria-label='Quick view {{ product.title }}'
      class='absolute bottom-3 left-1/2 -translate-x-1/2 translate-y-2 whitespace-nowrap rounded-2xl bg-white/95 px-5 py-2 text-xs font-bold text-on-surface shadow-bubbly opacity-0 transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 hover:bg-white focus:outline-none focus:ring-2 focus:ring-primary'
    >
      Quick view
    </button>
  </div>

  {{- '<!-- Content block -->' -}}
  <div class='flex flex-col gap-1 px-4 pb-4 pt-3'>
    {%- if product_subtitle != blank -%}
      <p class='text-xs font-semibold uppercase tracking-wide text-on-surface-variant'>
        {{ product_subtitle }}
      </p>
    {%- endif -%}

    <a href='{{ product.url }}'>
      <h3 class='line-clamp-2 text-sm font-bold leading-snug text-on-surface transition-colors hover:text-primary'>
        {{ product.title }}
      </h3>
    </a>

    {%- if product.metafields.reviews.rating.value != blank -%}
      <div class='text-xs'>
        {%- render 'rating-stars', product: product -%}
      </div>
    {%- endif -%}

    <div class='mt-1 flex items-center justify-between gap-2'>
      <div class='text-sm font-bold'>
        {%- render 'price', product: product -%}
      </div>
      {%- if low_stock -%}
        <p class='shrink-0 text-xs font-semibold text-secondary'>Only {{ low_stock_qty }} left</p>
      {%- endif -%}
    </div>
  </div>
</article>
