{%- comment -%}
  Reusable product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign badge_sale = false
  if product.compare_at_price > product.price
    assign badge_sale = true
  endif
  assign badge_vet = false
  if product.metafields.pet.vet_approved.value == true
    assign badge_vet = true
  endif
  assign product_subtitle = product.type
  if product_subtitle == blank
    assign product_subtitle = product.description | strip_html | truncatewords: 8
  endif
  assign card_variant = product.selected_or_first_available_variant
  assign low_stock = false
  assign low_stock_qty = 0
  if card_variant
    if card_variant.inventory_management != blank and card_variant.inventory_policy == 'deny'
      assign low_stock_qty = card_variant.inventory_quantity
      if low_stock_qty > 0 and low_stock_qty <= 5
        assign low_stock = true
      endif
    endif
  endif
-%}

<article class='product-card group bg-background rounded-3xl p-5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-bubbly'>
  <a href='{{ product.url }}' class='block' aria-label='{{ product.title }}'>
    <div class='relative aspect-square bg-white rounded-2xl mb-4 overflow-hidden flex items-center justify-center p-4'>
      {%- if product.featured_image != blank -%}
        {%- assign card_img_alt = product.featured_image.alt | default: product.title -%}
        {{
          product.featured_image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            width: 600,
            height: 600,
            class: 'w-full h-full object-contain transition-transform duration-700 group-hover:scale-105',
            alt: card_img_alt
        }}
      {%- else -%}
        <div class='flex h-full w-full items-center justify-center text-on-surface/20' aria-hidden='true'>
          {%- render 'icon', icon: 'paw' -%}
        </div>
      {%- endif -%}

      {%- if badge_vet or badge_sale or low_stock -%}
        <div class='absolute left-2.5 top-2.5 z-10 flex flex-col gap-1'>
          {%- if badge_vet -%}
            <span class='rounded-full bg-primary/90 px-2 py-0.5 text-xs font-bold leading-snug text-white'>
              {{ badge_vet_label | default: 'Vet Approved' }}
            </span>
          {%- endif -%}
          {%- if badge_sale -%}
            <span class='rounded-full bg-secondary px-2 py-0.5 text-xs font-bold leading-snug text-white'>
              {{ badge_sale_label | default: 'Sale' }}
            </span>
          {%- endif -%}
          {%- if low_stock -%}
            <span class='rounded-full bg-secondary/90 px-2 py-0.5 text-xs font-bold leading-snug text-white'>
              Low Stock
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- unless product.available -%}
        <div class='absolute inset-0 flex items-center justify-center rounded-2xl bg-surface/70'>
          <span class='rounded-full bg-on-surface/80 px-3 py-1 text-xs font-bold text-surface'>Sold Out</span>
        </div>
      {%- endunless -%}
    </div>

    {%- if product_subtitle != blank -%}
      <p class='mb-1 text-xs font-semibold uppercase tracking-wide text-on-surface-variant'>
        {{ product_subtitle }}
      </p>
    {%- endif -%}

    <h3 class='mb-1.5 line-clamp-2 text-sm font-bold leading-snug text-on-surface'>{{ product.title }}</h3>

    {%- if product.metafields.reviews.rating.value != blank -%}
      <div class='mb-3 text-xs'>
        {%- render 'rating-stars', product: product -%}
      </div>
    {%- else -%}
      <div class='mb-3' aria-hidden='true'></div>
    {%- endif -%}
  </a>

  {%- if low_stock -%}
    <p class='mb-2 text-xs font-semibold text-secondary'>Only {{ low_stock_qty }} left</p>
  {%- endif -%}

  <div class='flex items-center justify-between gap-2'>
    <div class='text-sm font-bold'>
      {%- render 'price', product: product -%}
    </div>
    <button
      type='button'
      data-quick-view-trigger
      data-product-handle='{{ product.handle }}'
      aria-label='Quick view {{ product.title }}'
      class='flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-2xl bg-white text-primary shadow-bubbly transition-all hover:scale-105 hover:bg-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-primary'
    >
      <span class='block h-4 w-4' aria-hidden='true'>
        {%- render 'icon', icon: 'cart-add' -%}
      </span>
    </button>
  </div>
</article>
