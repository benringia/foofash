{%- assign clinic_blocks = section.blocks | where: 'type', 'clinic_service' -%}
{%- assign nav_links = linklists[menu].links -%}
{%- assign shop_featured_links = linklists[section.settings.shop_featured_menu].links -%}
{%- assign shop_categories_links = linklists[section.settings.shop_categories_menu].links -%}
{%- assign has_shop_dropdown = false -%}
{%- if shop_featured_links.size > 0 or shop_categories_links.size > 0 -%}
  {%- assign has_shop_dropdown = true -%}
{%- endif -%}

{%- comment -%} Desktop navigation {%- endcomment -%}
<nav aria-label='Main navigation' class='hidden items-center gap-6 md:flex'>
  {%- for link in nav_links -%}
    {%- if link.links.size > 0 -%}
      <div class='relative' data-mega-menu>
        <button
          type='button'
          aria-expanded='false'
          aria-controls='mega-{{ link.handle }}'
          data-mega-trigger
          class='flex items-center gap-1 text-sm font-medium text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
        >
          {{- link.title -}}
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='16'
            height='16'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
            class='transition-transform duration-200'
            data-mega-chevron
          >
            <polyline points='6 9 12 15 18 9'></polyline>
          </svg>
        </button>

        <div
          id='mega-{{ link.handle }}'
          class='fixed left-1/2 z-50 w-[780px] max-w-[calc(100vw-2rem)] -translate-x-1/2 translate-y-2 rounded-3xl border border-surface-high bg-white opacity-0 shadow-bubbly-lg pointer-events-none transition-all duration-200 ease-out'
          aria-hidden='true'
          data-mega-panel
        >
          <div class='grid grid-cols-2 gap-2 p-6 sm:grid-cols-4'>
            {%- for child in link.links -%}
              <div class='rounded-2xl p-4 transition-colors hover:bg-surface-container-low'>
                <a
                  href='{{ child.url }}'
                  class='mb-1 block text-xs font-bold uppercase tracking-widest text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
                >
                  {{- child.title -}}
                </a>
                <div class='mb-4 h-0.5 w-6 rounded-full bg-secondary'></div>
                {%- if child.links.size > 0 -%}
                  <ul class='space-y-2'>
                    {%- for grandchild in child.links -%}
                      <li>
                        <a
                          href='{{ grandchild.url }}'
                          class='block text-sm text-on-surface-variant transition-all duration-150 hover:translate-x-1 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
                        >
                          {{- grandchild.title -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <a
        href='{{ link.url }}'
        class='text-sm font-medium text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
      >
        {{- link.title -}}
      </a>
    {%- endif -%}
  {%- endfor -%}
  {%- comment -%} Custom Shop dropdown — driven by header section link_lists {%- endcomment -%}
  {%- if has_shop_dropdown -%}
    <div class='relative' data-mega-menu>
      <button
        type='button'
        aria-expanded='false'
        aria-controls='mega-shop'
        data-mega-trigger
        class='flex items-center gap-1 text-sm font-medium text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
      >
        {{- section.settings.shop_nav_label | default: 'Shop' -}}
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='16'
          height='16'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          class='transition-transform duration-200'
          data-mega-chevron
        >
          <polyline points='6 9 12 15 18 9'></polyline>
        </svg>
      </button>

      <div
        id='mega-shop'
        class='fixed left-1/2 z-50 w-[580px] max-w-[calc(100vw-2rem)] -translate-x-1/2 translate-y-2 rounded-3xl border border-surface-high bg-white opacity-0 shadow-bubbly-lg pointer-events-none transition-all duration-200 ease-out'
        aria-hidden='true'
        data-mega-panel
      >
        {%- comment -%} Panel header {%- endcomment -%}
        <div class='border-b border-surface-high px-6 py-5'>
          <p class='text-xs font-bold uppercase tracking-widest text-primary'>
            {{- section.settings.shop_nav_label | default: 'Shop' -}}
          </p>
          <p class='mt-1 text-sm text-on-surface-variant'>Find the right product for your pet</p>
        </div>

        {%- comment -%} Two-column content {%- endcomment -%}
        <div class='{% if shop_featured_links.size > 0 and shop_categories_links.size > 0 %}grid grid-cols-2{% endif %} p-6'>
          {%- if shop_featured_links.size > 0 -%}
            <div class='{% if shop_categories_links.size > 0 %}pr-6 border-r border-surface-high{% endif %}'>
              <p class='mb-3 text-xs font-bold uppercase tracking-widest text-on-surface/40'>
                {{- section.settings.shop_featured_label | default: 'Featured' -}}
              </p>
              <ul class='space-y-0.5'>
                {%- for link in shop_featured_links -%}
                  <li>
                    <a
                      href='{{ link.url }}'
                      class='flex items-center gap-2 rounded-xl px-3 py-2 text-sm transition-colors hover:bg-surface-container-low focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 {% if forloop.first %}font-semibold text-primary{% else %}text-on-surface hover:text-primary{% endif %}'
                    >
                      <span
                        class='h-1.5 w-1.5 shrink-0 rounded-full {% if forloop.first %}bg-primary{% else %}bg-on-surface/20{% endif %}'
                        aria-hidden='true'
                      ></span>
                      {{- link.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- if shop_categories_links.size > 0 -%}
            <div class='{% if shop_featured_links.size > 0 %}pl-6{% endif %}'>
              <p class='mb-3 text-xs font-bold uppercase tracking-widest text-on-surface/40'>
                {{- section.settings.shop_categories_label | default: 'Shop by pet' -}}
              </p>
              <ul class='space-y-0.5'>
                {%- for link in shop_categories_links -%}
                  <li>
                    <a
                      href='{{ link.url }}'
                      class='flex items-center gap-2 rounded-xl px-3 py-2 text-sm text-on-surface transition-colors hover:bg-surface-container-low hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
                    >
                      <span class='h-4 w-4 shrink-0 text-primary/60' aria-hidden='true'>
                        {%- render 'icon', icon: 'paw' -%}
                      </span>
                      {{- link.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Panel footer CTA {%- endcomment -%}
        {%- if section.settings.shop_cta_url != blank -%}
          <div class='border-t border-surface-high px-6 py-4'>
            <a
              href='{{ section.settings.shop_cta_url }}'
              class='inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
            >
              {{- section.settings.shop_cta_label | default: 'Browse all products' -}}
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='14'
                height='14'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <line x1='5' y1='12' x2='19' y2='12'></line>
                <polyline points='12 5 19 12 12 19'></polyline>
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Custom Clinic dropdown — driven by header section blocks {%- endcomment -%}
  {%- if clinic_blocks.size > 0 -%}
    <div class='relative' data-mega-menu>
      <button
        type='button'
        aria-expanded='false'
        aria-controls='mega-clinic'
        data-mega-trigger
        class='flex items-center gap-1 text-sm font-medium text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
      >
        {{- section.settings.clinic_nav_label | default: 'Clinic' -}}
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='16'
          height='16'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
          class='transition-transform duration-200'
          data-mega-chevron
        >
          <polyline points='6 9 12 15 18 9'></polyline>
        </svg>
      </button>

      <div
        id='mega-clinic'
        class='fixed left-1/2 z-50 w-[520px] max-w-[calc(100vw-2rem)] -translate-x-1/2 translate-y-2 rounded-3xl border border-surface-high bg-white opacity-0 shadow-bubbly-lg pointer-events-none transition-all duration-200 ease-out'
        aria-hidden='true'
        data-mega-panel
      >
        {%- comment -%} Panel header {%- endcomment -%}
        <div class='border-b border-surface-high px-6 py-5'>
          <p class='text-xs font-bold uppercase tracking-widest text-primary'>
            {{- section.settings.clinic_nav_label | default: 'Clinic' }} Services
          </p>
          <p class='mt-1 text-sm text-on-surface-variant'>Book your pet's next visit</p>
        </div>

        {%- comment -%} Service cards grid {%- endcomment -%}
        <div class='grid grid-cols-2 gap-2 p-4'>
          {%- for block in clinic_blocks -%}
            {%- assign svc = block.settings.service_product -%}
            {%- if svc != blank -%}
              <a
                href='{{ svc.url }}'
                class='group flex items-start gap-3 rounded-2xl p-4 transition-all hover:bg-surface-container-low focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
              >
                <span
                  class='flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-primary/8 p-2 text-primary transition-transform group-hover:scale-110'
                  aria-hidden='true'
                >
                  {%- render 'icon', icon: block.settings.icon | default: 'stethoscope' -%}
                </span>
                <div class='min-w-0'>
                  <p class='text-sm font-semibold text-on-surface'>
                    {{- block.settings.label | default: svc.title -}}
                  </p>
                  {%- if block.settings.subtitle != blank -%}
                    <p class='mt-0.5 text-xs leading-relaxed text-on-surface-variant'>
                      {{- block.settings.subtitle -}}
                    </p>
                  {%- endif -%}
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Panel footer CTA {%- endcomment -%}
        {%- if section.settings.clinic_cta_url != blank -%}
          <div class='border-t border-surface-high px-6 py-4'>
            <a
              href='{{ section.settings.clinic_cta_url }}'
              class='inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
            >
              {{- section.settings.clinic_cta_label | default: 'View all clinic services' -}}
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='14'
                height='14'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                aria-hidden='true'
              >
                <line x1='5' y1='12' x2='19' y2='12'></line>
                <polyline points='12 5 19 12 12 19'></polyline>
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if services_page != blank -%}
    <a
      href='{{ services_page }}'
      class='text-sm font-medium text-on-surface transition-colors hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded'
    >
      {{ services_label | default: 'Services' }}
    </a>
  {%- endif -%}
</nav>
