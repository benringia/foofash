{%- comment -%}
  Sticky Add-to-Cart bar. Rendered at the bottom of main-product.liquid.
  Hidden by default; sticky-atc.js shows it via IntersectionObserver when
  the main ATC button [data-main-atc] scrolls out of view.

  Usage: {% render 'sticky-atc', product: product %}
{%- endcomment -%}

{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign sticky_btn_label = cta_label | default: 'Add to Cart' -%}
{%- assign sticky_btn_sold_out = cta_sold_out_label | default: 'Sold Out' -%}

<div
  data-sticky-atc
  aria-hidden='true'
  class='fixed bottom-0 left-0 z-40 w-full translate-y-full bg-surface shadow-[0_-4px_20px_-4px_rgba(45,106,79,0.12)] transition-transform duration-300 ease-in-out'
>
  <div class='mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6 lg:px-8'>
    {%- comment -%} Product thumbnail {%- endcomment -%}
    {%- if product.featured_image != blank -%}
      <div class='hidden shrink-0 sm:block'>
        {{
          product.featured_image
          | image_url: width: 80
          | image_tag:
            loading: 'lazy',
            width: 40,
            height: 40,
            class: 'h-10 w-10 rounded-xl object-cover',
            alt: product.featured_image.alt
          | default: product.title
        }}
      </div>
    {%- endif -%}

    {%- comment -%} Title + price {%- endcomment -%}
    <div class='min-w-0 flex-1'>
      <p class='truncate text-sm font-semibold text-on-surface'>
        {{ product.title }}
      </p>
      {%- unless product.has_only_default_variant -%}
        <p data-sticky-atc-variant class='truncate text-xs text-on-surface-variant/70'>
          {{- variant.title -}}
        </p>
      {%- endunless -%}
      <div data-sticky-atc-price class='text-sm text-on-surface-variant'>
        {%- render 'price', product: product, variant: variant -%}
      </div>
    </div>

    {%- comment -%} CTA {%- endcomment -%}
    <button
      type='button'
      data-sticky-atc-btn
      {%- unless variant.available -%}
        disabled
        aria-disabled='true'
      {%- endunless -%}
      class='shrink-0 rounded-2xl bg-primary-gradient px-6 py-2.5 text-sm font-bold text-on-primary transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:scale-100 disabled:cursor-not-allowed disabled:opacity-50'
    >
      {%- if variant.available -%}
        {{ sticky_btn_label }}
      {%- else -%}
        {{ sticky_btn_sold_out }}
      {%- endif -%}
    </button>
  </div>
</div>
