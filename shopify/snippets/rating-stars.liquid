{%- comment -%}
  Rating stars snippet.
  Usage: {% render 'rating-stars', product: product %}

  Reads product.metafields.reviews.rating.value (Shopify Product Reviews app standard).
  Falls back to decorative 5-star display for stores without a ratings app.
{%- endcomment -%}

{%- assign rating_value = product.metafields.reviews.rating.value -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}

{%- if rating_value != blank -%}
  {%- assign rating_num = rating_value | times: 1.0 -%}
  {%- assign full_stars = rating_num | floor -%}
  {%- assign has_half = false -%}
  {%- assign remainder = rating_num | minus: full_stars -%}
  {%- if remainder >= 0.25 and remainder < 0.75 -%}
    {%- assign has_half = true -%}
  {%- elsif remainder >= 0.75 -%}
    {%- assign full_stars = full_stars | plus: 1 -%}
  {%- endif -%}
  {%- assign half_star_pos = full_stars | plus: 1 -%}

  <div
    class='flex items-center gap-2'
    role='img'
    aria-label='Rated {{ rating_num | round: 1 }} out of 5 stars{% if rating_count > 0 %}, {{ rating_count }} reviews{% endif %}'
  >
    <div class='flex items-center gap-0.5' aria-hidden='true'>
      {%- for i in (1..5) -%}
        {%- if i <= full_stars -%}
          {%- comment -%} Full star {%- endcomment -%}
          <svg class='h-4 w-4 text-secondary' viewBox='0 0 20 20' fill='currentColor' aria-hidden='true'>
            <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z'/>
          </svg>
        {%- elsif has_half and i == half_star_pos -%}
          {%- comment -%} Half star {%- endcomment -%}
          <svg class='h-4 w-4' viewBox='0 0 20 20' aria-hidden='true'>
            <defs>
              <linearGradient id='half-grad-{{ product.id }}' x1='0' x2='1' y1='0' y2='0'>
                <stop offset='50%' stop-color='currentColor' class='text-secondary'/>
                <stop offset='50%' stop-color='currentColor' class='text-on-surface/20'/>
              </linearGradient>
            </defs>
            <path fill='url(#half-grad-{{ product.id }})' d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z'/>
          </svg>
        {%- else -%}
          {%- comment -%} Empty star {%- endcomment -%}
          <svg class='h-4 w-4 text-on-surface/20' viewBox='0 0 20 20' fill='currentColor' aria-hidden='true'>
            <path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z'/>
          </svg>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if rating_count > 0 -%}
      <span class='text-sm font-medium text-on-surface-variant'>
        {{ rating_num | round: 1 }} ({{ rating_count }} review
        {%- if rating_count != 1 -%}s{%- endif -%}
        )
      </span>
    {%- else -%}
      <span class='text-sm font-medium text-on-surface-variant'>
        {{ rating_num | round: 1 }}
      </span>
    {%- endif -%}
  </div>

  {%- comment -%} No real rating data — render nothing {%- endcomment -%}
{%- endif -%}
