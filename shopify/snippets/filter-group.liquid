{%- comment -%}
  Filter group rendered as an accordion using native <details>/<summary>.
  Usage: {% render 'filter-group', filter: filter %}
{%- endcomment -%}

<details class='border-b border-gray-200 py-4' open>
  <summary class='flex cursor-pointer list-none items-center justify-between'>
    <span class='text-sm font-semibold text-gray-900'>{{ filter.label }}</span>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      width='16'
      height='16'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      aria-hidden='true'
      focusable='false'
      class='text-gray-400 transition-transform duration-200 [[open]_&]:rotate-180'
    >
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </summary>

  <div class='mt-3 flex flex-col gap-1'>
    {%- for value in filter.values -%}
      {%- if value.active -%}
        <a
          href='{{ value.url_to_remove }}'
          class='group flex items-center gap-2.5 rounded-md px-1 py-1.5 text-sm text-green-800 hover:bg-gray-50'
          aria-label='Remove filter: {{ filter.label }} {{ value.label }}'
        >
          <span class='flex h-4 w-4 flex-none items-center justify-center rounded border-2 border-green-600 bg-green-600'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='10'
              height='10'
              viewBox='0 0 24 24'
              fill='none'
              stroke='white'
              stroke-width='3'
              stroke-linecap='round'
              stroke-linejoin='round'
              aria-hidden='true'
              focusable='false'
            >
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          <span class='font-medium'>{{ value.label }}</span>
          <span class='ml-auto text-xs text-gray-400'>({{ value.count }})</span>
        </a>
      {%- elsif value.count > 0 -%}
        <a
          href='{{ value.url_to_add }}'
          class='flex items-center gap-2.5 rounded-md px-1 py-1.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gray-900'
          aria-label='Add filter: {{ filter.label }} {{ value.label }}'
        >
          <span
            class='flex h-4 w-4 flex-none items-center justify-center rounded border-2 border-gray-300 group-hover:border-gray-400'
          ></span>
          {{ value.label }}
          <span class='ml-auto text-xs text-gray-400'>({{ value.count }})</span>
        </a>
      {%- else -%}
        <span
          class='flex cursor-not-allowed items-center gap-2.5 rounded-md px-1 py-1.5 text-sm text-gray-300'
          aria-disabled='true'
        >
          <span class='flex h-4 w-4 flex-none items-center justify-center rounded border-2 border-gray-200'></span>
          {{ value.label }}
          <span class='ml-auto text-xs'>(0)</span>
        </span>
      {%- endif -%}
    {%- endfor -%}
  </div>
</details>
