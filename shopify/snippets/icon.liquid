{%- comment -%}
  Renders an inline SVG icon.
  Usage: {% render 'icon', icon: 'vet-approved' %}
  Supported: vet-approved, shipping, returns, paw, clock, phone, stethoscope, scissors, syringe, tooth
{%- endcomment -%}

{%- case icon -%}
  {%- when 'vet-approved' -%}
