{%- comment -%}
  Quick View modal shell. Rendered once in theme.liquid before </body>.
  quick-view.js populates [data-quick-view-content] and controls open/close.
{%- endcomment -%}

<div
  data-quick-view-overlay
  class='fixed inset-0 z-50 hidden bg-black/60'
  aria-hidden='true'
></div>

<div
  data-quick-view-modal
  role='dialog'
  aria-modal='true'
  aria-label='Quick view'
  aria-hidden='true'
  class='fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-8'
>
  <div class='relative flex max-h-[90vh] w-full max-w-2xl flex-col overflow-hidden rounded-xl bg-white shadow-2xl'>
    <button
      type='button'
      data-quick-view-close
      aria-label='Close quick view'
      class='absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300'
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='20'
        height='20'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        aria-hidden='true'
        focusable='false'
      >
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div data-quick-view-content class='overflow-y-auto p-6'>
      {{- '' -}}
    </div>
  </div>
</div>
