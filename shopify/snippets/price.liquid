{%- comment -%}
  Renders product price with sale/compare-at logic.
  Usage: {% render 'price', product: product %}
  Also accepts a variant: {% render 'price', product: product, variant: variant %}
{%- endcomment -%}

{%- liquid
  assign target = variant | default: product
  assign price = target.price
  assign compare_price = target.compare_at_price
  assign on_sale = false
  if compare_price > price
    assign on_sale = true
  endif
-%}

<div class='price'>
  {%- if on_sale -%}
    <span class='price__sale text-red-600 font-semibold'>
      <span class='sr-only'>Sale price</span>
      {{ price | money }}
    </span>
    <s class='price__compare text-gray-400 text-sm ml-1'>
      <span class='sr-only'>Regular price</span>
      {{ compare_price | money }}
    </s>
  {%- else -%}
    <span class='price__regular font-semibold text-gray-900'>
      {{ price | money }}
    </span>
  {%- endif -%}
</div>
