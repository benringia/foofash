<!doctype html>
<html lang='{{ request.locale.iso_code }}' dir='auto'>
  <head>
    <meta charset='utf-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <title>
      {{ page_title }}
      {% if page_title != blank %} – {% endif %}
      {{ shop.name }}
    </title>
    <link rel='preconnect' href='https://fonts.googleapis.com'>
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin>
    <link
      href='https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap'
      rel='stylesheet'
    >
    <style>
      body {
        font-family: 'Be Vietnam Pro', sans-serif;
        background-color: #fffcf5;
        color: #383833;
      }
    </style>
    {% render 'vite-assets' %}
    {{ content_for_header }}
  </head>
  <body>
    <a
      href='#main-content'
      class='sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-white focus:text-black'
    >
      Skip to content
    </a>
    {% section 'header' %}
    <main id='main-content' tabindex='-1'>
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
    {% render 'cart-drawer' %}
    {% render 'quick-view-modal' %}
  </body>
</html>
