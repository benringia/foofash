{
  "name": "foofash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"shopify theme dev --path shopify --store foofash.myshopify.com\"",
    "build": "vite build",
    "clean": "rimraf shopify/assets/main.css shopify/assets/main.js shopify/assets/.vite",
    "push": "shopify theme push --path shopify --store foofash.myshopify.com",
    "test": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
